---
import Layout from "./Layout.astro";
import { Image } from "astro:assets";
import SkillBadge from "../components/SkillBadge.astro";
import Giscus from "../components/Giscus.astro";
import TableOfContents from "../components/TableOfContents.astro";
import RelatedContent from "../components/RelatedContent.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import BackToTop from "../components/BackToTop.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  image: any;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
}

const { id, title, description, publishDate, updatedDate, image, tags, headings } =
  Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

// Reading time is now handled differently or approximated
const readingTime = 10; // Placeholder for now to test the fix
---

<Layout title={title} description={description}>
  <ReadingProgress />
  <BackToTop />
  <article class="max-w-4xl mx-auto px-4 py-20">
    <!-- Back button -->
    <div class="mb-8">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        ブログ一覧へ
      </a>
    </div>

    <!-- Featured Image -->
    {
      image && (
        <figure class="mb-8 rounded-2xl overflow-hidden">
          <Image
            src={image}
            alt={title}
            class="w-full aspect-video object-cover"
            width={1200}
            height={630}
          />
        </figure>
      )
    }

    <!-- Post Header -->
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      <p class="text-lg text-base-content/70 mb-4">{description}</p>

      <div
        class="flex flex-wrap items-center gap-4 text-sm text-base-content/60"
      >
        <time datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>
        <span>&bull;</span>
        <span>読了目安: 約{readingTime}分</span>
        {
          updatedDate && (
            <>
              <span>&bull;</span>
              <span>最終更新日: {formatDate(updatedDate)}</span>
            </>
          )
        }
      </div>

      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <SkillBadge
                skill={tag}
                href={`${import.meta.env.BASE_URL}blog?tag=${encodeURIComponent(tag.toLowerCase())}`}
              />
            ))}
          </div>
        )
      }
    </header>

    <!-- Divider -->
    <div class="divider"></div>

    <!-- Table of Contents (Now at top) -->
    <TableOfContents headings={headings} />

    <!-- Content Body -->
    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <slot />
    </div>

    <!-- Related Content -->
    <RelatedContent 
      currentId={id} 
      collection="blog" 
      tags={tags || []} 
    />

    <!-- Giscus Comments -->
    <Giscus />

    <!-- Divider -->
    <div class="divider mt-12"></div>

    <!-- Back to blog link -->
    <div class="text-center mt-8">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-primary">
        すべての記事を見る
      </a>
    </div>
  </article>
</Layout>
