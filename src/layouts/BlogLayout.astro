---
import Layout from "./Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SkillBadge from "../components/SkillBadge.astro";
import Giscus from "../components/Giscus.astro";
import ShareBar from "../components/ShareBar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import RelatedContent from "../components/RelatedContent.astro";
import PrevNextNav from "../components/PrevNextNav.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import BackToTop from "../components/BackToTop.astro";
import "katex/dist/katex.min.css";
import { formatDate } from "../utils/formatDate";
import { SITE } from "../utils/site";
import { useTranslations, type Lang } from "../i18n/ui";

interface NavEntry {
  title: string;
  description: string;
  url: string;
}

interface Props {
  id: string;
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  image?: ImageMetadata;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
  readingTime: number;
  prev?: NavEntry;
  next?: NavEntry;
}

const { id, title, description, publishDate, updatedDate, image, tags, headings, readingTime, prev, next } =
  Astro.props;

const hasToc = headings.some((h) => h.depth <= 3);
const locale = (Astro.currentLocale ?? "ja") as Lang;
const t = useTranslations(locale);
const ownerName = locale === "en" ? SITE.ownerName : SITE.ownerNameJa;

const ogImage = image
  ? `${Astro.url.origin}${typeof image === "object" && "src" in image ? image.src : image}`
  : `${Astro.url.origin}${import.meta.env.BASE_URL}og/blog/${id}.png`;

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": publishDate.toISOString(),
  "dateModified": (updatedDate ?? publishDate).toISOString(),
  "author": { "@type": "Person", "name": SITE.ownerName, "url": Astro.url.origin },
  "url": Astro.url.href,
  "image": ogImage,
  ...(tags && tags.length > 0 ? { "keywords": tags.join(", ") } : {}),
};
---

<Layout title={`${title} - ${ownerName}`} description={description} ogImage={ogImage} ogImageWidth={800} ogImageHeight={450}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={publishDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={SITE.ownerName} />
  </Fragment>
  <ReadingProgress />
  <BackToTop />
  <main id="main-content" class="max-w-6xl mx-auto px-4 pt-20 pb-16">
    <!-- Back button -->
    <div class="mb-8">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-soft btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        {t("blog.backToList")}
      </a>
    </div>

    <div class:list={[hasToc && "lg:grid lg:grid-cols-[minmax(0,1fr)_15rem] lg:gap-12 xl:gap-16"]}>
      <article class="min-w-0">
        <div class="max-w-3xl mx-auto">
          <!-- Featured Image -->
          {
            image && (
              <figure class="mb-8 rounded-lg overflow-hidden border border-base-200">
              <Image
                src={image}
                alt={title}
                class="w-full aspect-video object-cover"
                width={1200}
                height={630}
              />
              </figure>
            )}

          <!-- Post Header -->
          <header class="mb-8 border border-base-200 bg-base-100 rounded-lg p-6 sm:p-8">
            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-4">BLOG</p>
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-4">{title}</h1>
            <p class="text-base sm:text-lg text-base-content/70 mb-4">{description}</p>

            <div class="flex flex-wrap items-center gap-4 text-sm text-base-content/60">
              <time datetime={publishDate.toISOString()}>
                {formatDate(publishDate)}
              </time>
              <span>&bull;</span>
              <span>{t("blog.readingTimePrefix")}: {t("blog.readingTime").replace("{n}", String(readingTime))}</span>
              {
                updatedDate && (
                  <>
                    <span>&bull;</span>
                    <span>{t("blog.lastUpdated")}: {formatDate(updatedDate)}</span>
                  </>
                )
              }
            </div>

            {
              tags && tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {tags.map((tag) => (
                    <SkillBadge
                      skill={tag}
                      href={`${import.meta.env.BASE_URL}blog/tags/${tag}`}
                    />
                  ))}
                </div>
              )
            }

            <ShareBar title={title} description={description} url={Astro.url.href} />
          </header>

          <!-- Divider -->
          <div class="divider"></div>

          <!-- TOC (collapsible, mobile/tablet only) -->
          <div class="mb-8 lg:hidden">
            <TableOfContents headings={headings} />
          </div>

          <!-- Content Body -->
          <div class="prose max-w-none prose-headings:text-primary prose-h2:border-b-2 prose-h2:border-primary prose-h2:pb-2 prose-h3:border-l-4 prose-h3:border-primary prose-h3:pl-3 prose-img:mx-auto prose-img:block prose-img:max-w-full sm:prose-img:max-w-2xl prose-img:rounded-lg">
            <slot />
          </div>

          <!-- Prev / Next Navigation -->
          <PrevNextNav prev={prev} next={next} collection="blog" />

          <!-- Related Content -->
          <RelatedContent
            currentId={id}
            collection="blog"
            tags={tags || []}
          />

          <!-- Giscus Comments -->
          <Giscus />

          <!-- Divider -->
          <div class="divider mt-12"></div>

          <!-- Back to blog link -->
          <div class="text-center mt-8">
            <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-primary">
              {t("blog.allPosts")}
            </a>
          </div>
        </div>
      </article>

      {
        hasToc && (
          <aside class="hidden lg:block">
            <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto overscroll-contain pb-4">
              <TableOfContents headings={headings} sidebar={true} />
            </div>
          </aside>
        )
      }
    </div>
  </main>
</Layout>
