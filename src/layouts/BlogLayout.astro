---
import Layout from "./Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import OgPlaceholder from "../components/OgPlaceholder.astro";
import SkillBadge from "../components/SkillBadge.astro";
import Giscus from "../components/Giscus.astro";
import TableOfContents from "../components/TableOfContents.astro";
import RelatedContent from "../components/RelatedContent.astro";
import PrevNextNav from "../components/PrevNextNav.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import BackToTop from "../components/BackToTop.astro";
import "katex/dist/katex.min.css";
import { formatDate } from "../utils/formatDate";

interface NavEntry {
  title: string;
  description: string;
  url: string;
}

interface Props {
  id: string;
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  image?: ImageMetadata;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
  readingTime: number;
  prev?: NavEntry;
  next?: NavEntry;
}

const { id, title, description, publishDate, updatedDate, image, tags, headings, readingTime, prev, next } =
  Astro.props;

const ogImage = image
  ? `${Astro.url.origin}${typeof image === "object" && "src" in image ? image.src : image}`
  : `${Astro.url.origin}${import.meta.env.BASE_URL}og/blog/${id}.png`;
---

<Layout title={title} description={description} ogImage={ogImage} ogImageWidth={800} ogImageHeight={450}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={publishDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content="Keitaro Ueki" />
  </Fragment>
  <ReadingProgress />
  <BackToTop />
  <div class="max-w-6xl mx-auto px-4 py-20">
    <!-- Back button -->
    <div class="mb-8">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-soft btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Blog
      </a>
    </div>

    <!-- Featured Image -->
    <figure class="mb-8 max-w-3xl mx-auto rounded-2xl overflow-hidden">
      {image ? (
        <Image
          src={image}
          alt={title}
          class="w-full aspect-video object-cover"
          width={1200}
          height={630}
        />
      ) : (
        <OgPlaceholder id={id} title={title} tags={tags} label="BLOG" />
      )}
    </figure>

    <!-- Post Header -->
    <header class="mb-8">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-4">{title}</h1>
      <p class="text-base sm:text-lg text-base-content/70 mb-4">{description}</p>

      <div class="flex flex-wrap items-center gap-4 text-sm text-base-content/60">
        <time datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>
        <span>&bull;</span>
        <span>~{readingTime} min read</span>
        {
          updatedDate && (
            <>
              <span>&bull;</span>
              <span>Updated: {formatDate(updatedDate)}</span>
            </>
          )
        }
      </div>

      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <SkillBadge
                skill={tag}
                href={`${import.meta.env.BASE_URL}blog?tag=${encodeURIComponent(tag.toLowerCase())}`}
              />
            ))}
          </div>
        )
      }
    </header>

    <!-- Divider -->
    <div class="divider"></div>

    <div class="lg:grid lg:grid-cols-[1fr_16rem] lg:gap-12 lg:items-start">
      <article>
        <!-- TOC (mobile/tablet: collapsible at top) -->
        <div class="mb-8 lg:hidden">
          <TableOfContents headings={headings} />
        </div>

        <!-- Content Body -->
        <div class="prose max-w-none prose-headings:text-primary prose-h2:border-b-2 prose-h2:border-primary prose-h2:pb-2 prose-h3:border-l-4 prose-h3:border-primary prose-h3:pl-3 prose-img:mx-auto prose-img:block">
          <slot />
        </div>

        <!-- Prev / Next Navigation -->
        <PrevNextNav prev={prev} next={next} collection="blog" />

        <!-- Related Content -->
        <RelatedContent
          currentId={id}
          collection="blog"
          tags={tags || []}
        />

        <!-- Giscus Comments -->
        <Giscus />

        <!-- Divider -->
        <div class="divider mt-12"></div>

        <!-- Back to blog link -->
        <div class="text-center mt-8">
          <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-primary">
            View all posts
          </a>
        </div>
      </article>

      <!-- Sidebar TOC (desktop only, sticky) -->
      <aside class="hidden lg:block">
        <div class="sticky top-8">
          <TableOfContents headings={headings} sidebar={true} />
        </div>
      </aside>
    </div>
  </div>
</Layout>
