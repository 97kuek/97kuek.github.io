---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import ThemeSelector from "../components/ThemeSelector.astro";
import FabFlower from "../components/FabFlower.astro";
import Dock from "../components/Dock.astro";
import { getEntry } from "astro:content";

// Load general singleton
const generalEntry = (await getEntry("general", "index"))!;
const general = generalEntry.data;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bloomfolio Template",
  description = "A modern portfolio template built with Astro and DaisyUI",
} = Astro.props;

const origin = Astro.url.origin;
---

<!doctype html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={origin} />
    <meta property="og:image" content={`${origin}/images/og_home.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${origin}/images/og_home.png`} />

    <!-- KaTeX CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-n9XVv97Z8NHmH6PQs6pLLle7uLkkqfaV8i9i08nVLS0S9v9S2W6E7MlgJJ3V99P8"
      crossorigin="anonymous"
    />
  </head>
  <body class="min-h-screen">
    <!-- Theme Controls - Fixed Position -->
    <div class="fixed top-4 right-4 z-50">
      {general.enableThemeSelector ? <ThemeSelector /> : <ThemeToggle />}
    </div>

    <slot />

    {
      general.extraLinksEnabled && (
        <>
          {/* FabFlower for desktop - show 'both' and 'fab' items */}
          <FabFlower
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "dock",
            )}
          />
          {/* Dock for mobile - show 'both' and 'dock' items */}
          <Dock
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "fab",
            )}
          />
        </>
      )
    }

    <!-- Smooth Scroll -->
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </body>
</html>
