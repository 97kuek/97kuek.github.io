---
import "../styles/global.css";
import FabFlower from "../components/FabFlower.astro";
import Dock from "../components/Dock.astro";
import Navbar from "../components/Navbar.astro";
import ImageLightbox from "../components/ImageLightbox.astro";
import { ClientRouter } from "astro:transitions";
import { getEntry } from "astro:content";

// Load general singleton
const generalEntry = (await getEntry("general", "index"))!;
const general = generalEntry.data;

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const isEn = (Astro.currentLocale ?? "ja") === "en";
const defaultTitle = isEn ? "Keitaro Ueki - Portfolio" : "植木敬太郎 - Portfolio";
const defaultDescription = isEn
  ? "Portfolio of Keitaro Ueki (植木敬太郎), software engineering student at Waseda University."
  : "植木敬太郎（Keitaro Ueki）のポートフォリオ。早稲田大学基幹理工学部在籍。プロジェクトや技術ブログを公開中。";

const {
  title = defaultTitle,
  description = defaultDescription,
  ogImage,
  ogImageWidth,
  ogImageHeight,
} = Astro.props;

const origin = Astro.url.origin;
const ogImageUrl = ogImage ?? `${origin}${import.meta.env.BASE_URL}og/home.png`;
const locale = Astro.currentLocale ?? "ja";

// hreflang: only output alternates for pages that actually have a translation
// (top page, projects list/detail, search). Blog is Japanese-only.
const path = Astro.url.pathname;
const isEnPath = path === "/en" || path.startsWith("/en/");
const jaPathRaw = isEnPath ? path.replace(/^\/en(\/|$)/, "/") : path;
const jaPath = jaPathRaw.endsWith("/") ? jaPathRaw : `${jaPathRaw}/`;
const enPath = jaPath === "/" ? "/en/" : `/en${jaPath}`;
const hasTranslation =
  jaPath === "/" || jaPath.startsWith("/projects/") || jaPath === "/search/";
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="植木敬太郎 Keitaro Ueki" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={Astro.url.href} />
    {
      hasTranslation && (
        <>
          <link rel="alternate" hreflang="ja" href={`${origin}${jaPath}`} />
          <link rel="alternate" hreflang="en" href={`${origin}${enPath}`} />
          <link rel="alternate" hreflang="x-default" href={`${origin}${jaPath}`} />
        </>
      )
    }

    <!-- Apply theme before paint to avoid a flash of the wrong theme -->
    <script is:inline>
      (function () {
        function applyTheme() {
          var stored = localStorage.getItem("theme");
          var theme =
            stored ||
            (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", theme);
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=BIZ+UDPGothic:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Google Search Console -->
    <meta name="google-site-verification" content="IdV4d4hYTHpXQOAso7eobHRcWXJw_-bXMiMWMRdth3k" />
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Keitaro Ueki のブログ" href="/rss.xml" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[200] btn btn-primary btn-sm"
    >
      {isEn ? "Skip to content" : "本文へスキップ"}
    </a>
    <Navbar />
    <slot />

    {
      general.extraLinksEnabled && (
        <>
          {/* FabFlower for desktop - show 'both' and 'fab' items */}
          <FabFlower
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "dock",
            )}
          />
          {/* Dock for mobile - show 'both' and 'dock' items */}
          <Dock
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "fab",
            )}
          />
        </>
      )
    }

    <!-- Image Lightbox -->
    <ImageLightbox />
  </body>
</html>

