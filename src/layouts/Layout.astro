---
import "../styles/global.css";
import FabFlower from "../components/FabFlower.astro";
import Dock from "../components/Dock.astro";
import { getEntry } from "astro:content";

// Load general singleton
const generalEntry = (await getEntry("general", "index"))!;
const general = generalEntry.data;

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Bloomfolio Template",
  description = "A modern portfolio template built with Astro and DaisyUI",
  ogImage,
} = Astro.props;

const origin = Astro.url.origin;
const ogImageUrl = ogImage ?? `${origin}/images/og_home.png`;
---

<!doctype html>
<html lang="ja" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=BIZ+UDPGothic:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />

    {
      general.extraLinksEnabled && (
        <>
          {/* FabFlower for desktop - show 'both' and 'fab' items */}
          <FabFlower
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "dock",
            )}
          />
          {/* Dock for mobile - show 'both' and 'dock' items */}
          <Dock
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "fab",
            )}
          />
        </>
      )
    }

    <!-- Smooth Scroll -->
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </body>
</html>

