---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import OgPlaceholder from "../../../components/OgPlaceholder.astro";
import { formatDate, calcReadingTime } from "../../../utils/formatDate";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props as { tag: string };

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => (p.data.tags ?? []).includes(tag))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<Layout
  title={`#${tag} - ブログ - 97kuek`}
  description={`「${tag}」タグの記事一覧（${posts.length}件）`}
>
  <main class="max-w-6xl mx-auto px-4 py-20">
    <div class="mb-8">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        ブログ一覧へ
      </a>
    </div>

    <div class="mb-16">
      <p class="text-base font-bold tracking-widest text-primary uppercase mb-3">TAG</p>
      <h1 class="text-3xl font-bold mb-2">#{tag}</h1>
      <p class="text-base-content/60">{posts.length}件の記事</p>
    </div>

    {
      posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-2xl text-base-content/60">該当する記事がありません。</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a
              href={`${import.meta.env.BASE_URL}blog/${post.id}`}
              class="block group"
            >
              <article class="card bg-base-100 border border-base-200 hover:border-primary/20 transition-colors duration-200 h-full">
                <figure class="aspect-video overflow-hidden">
                  {post.data.image ? (
                    <Image
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                      width={600}
                      height={400}
                    />
                  ) : (
                    <OgPlaceholder id={post.id} title={post.data.title} tags={post.data.tags} showText={false} />
                  )}
                </figure>
                <div class="card-body">
                  <div class="flex items-center gap-2 text-sm text-base-content/60">
                    <time>{formatDate(post.data.publishDate)}</time>
                    <span>&bull;</span>
                    <span>約{calcReadingTime(post.body ?? "")}分</span>
                  </div>
                  <h2 class="card-title group-hover:text-primary transition-colors">{post.data.title}</h2>
                  <p class="text-base-content/70 text-sm">{post.data.description}</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {post.data.tags.map((t) => (
                        <a
                          href={`${import.meta.env.BASE_URL}blog/tags/${t}`}
                          class={`text-[0.65rem] leading-none px-1.5 py-0.5 rounded-full border transition-colors relative z-10 ${
                            t === tag
                              ? "bg-primary text-primary-content border-primary"
                              : "bg-primary/10 text-primary border-primary/20 hover:bg-primary/20"
                          }`}
                          onclick="event.stopPropagation()"
                        >
                          {t}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            </a>
          ))}
        </div>
      )
    }
  </main>
</Layout>
