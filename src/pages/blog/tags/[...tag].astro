---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import BlogCard from "../../../components/BlogCard.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props as { tag: string };

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => (p.data.tags ?? []).includes(tag))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<Layout
  title={`#${tag} - ブログ - 植木敬太郎`}
  description={`「${tag}」タグの記事一覧（${posts.length}件）`}
>
  <main id="main-content" class="max-w-6xl mx-auto px-4 py-20">
    <div class="mb-8">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        ブログ一覧へ
      </a>
    </div>

    <div class="mb-16">
      <p class="text-base font-bold tracking-widest text-primary uppercase mb-3">TAG</p>
      <h1 class="text-3xl font-bold mb-2">#{tag}</h1>
      <p class="text-base-content/60">{posts.length}件の記事</p>
    </div>

    {
      posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-2xl text-base-content/60">該当する記事がありません。</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <BlogCard post={post} headingLevel="h2" highlightTag={tag} />
          ))}
        </div>
      )
    }
  </main>
</Layout>
