---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import OgPlaceholder from "../../components/OgPlaceholder.astro";
import FilterSection from "../../components/FilterSection.astro";

const blogPosts = await getCollection("blog");

// Sort by publish date, most recent first
const sortedPosts = [...blogPosts].sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

// Get unique tags and counts
const allTags = [...new Set(blogPosts.flatMap(post => post.data.tags || []))].sort();
const tagCounts = blogPosts.reduce((acc, post) => {
  (post.data.tags || []).forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

function calcReadingTime(body: string): number {
  const japaneseChars = (body.match(/[　-鿿＀-￯]/g) ?? []).length;
  const englishWords = (body.match(/[a-zA-Z]+/g) ?? []).length;
  return Math.max(1, Math.ceil(japaneseChars / 500 + englishWords / 200));
}

function formatDate(date: Date) {
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title="ブログ - 97kuek"
  description="最新の技術記事や開発の記録を掲載しています"
>
  <main class="max-w-6xl mx-auto px-4 py-20">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold mb-4">ブログ</h1>
      <p class="text-xl text-base-content/70">
        開発、デザイン、テクノロジーに関する考えや学びを記録しています。
      </p>
    </div>

    <!-- Back to Home -->
    <div class="mb-8">
      <a href={import.meta.env.BASE_URL} class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        ホームに戻る
      </a>
    </div>

    <!-- Filter -->
    <FilterSection tags={allTags} tagCounts={tagCounts} totalCount={sortedPosts.length} containerId="blog-grid" />

    <!-- Blog Posts Grid -->
    {
      sortedPosts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-2xl text-base-content/60">
            まだ記事がありません。公開をお楽しみに！
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-grid">
          {sortedPosts.map((post) => (
            <a
              href={`${import.meta.env.BASE_URL}blog/${post.id}`}
              class="block group"
              data-filter-tags={(post.data.tags || []).join(",")}
            >
              <article class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md hover:border-primary/20 hover:-translate-y-0.5 transition-all duration-200 h-full">
                <figure class="aspect-video overflow-hidden">
                  {post.data.image ? (
                    <Image
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                      width={600}
                      height={400}
                    />
                  ) : (
                    <OgPlaceholder id={post.id} title={post.data.title} tags={post.data.tags} showText={false} />
                  )}
                </figure>
                <div class="card-body">
                  <div class="flex items-center gap-2 text-sm text-base-content/60">
                    <time>{formatDate(post.data.publishDate)}</time>
                    <span>&bull;</span>
                    <span>約{calcReadingTime(post.body ?? '')}分</span>
                  </div>
                  <h2 class="card-title group-hover:text-primary transition-colors">{post.data.title}</h2>
                  <p class="text-base-content/70 text-sm">{post.data.description}</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {post.data.tags.map((tag) => (
                        <span class="text-[0.65rem] leading-none px-1.5 py-0.5 rounded-full bg-primary/10 text-primary border border-primary/20">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            </a>
          ))}
        </div>
      )
    }
  </main>
</Layout>
