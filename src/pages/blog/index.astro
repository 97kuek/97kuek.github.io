---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import SkillBadge from "../../components/SkillBadge.astro";
import FilterSection from "../../components/FilterSection.astro";

const blogPosts = await getCollection("blog");

// Sort by publish date, most recent first
const sortedPosts = blogPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

// Get unique tags
const allTags = [...new Set(blogPosts.flatMap(post => post.data.tags || []))].sort();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---

<Layout
  title="ブログ - 97kuek"
  description="最新の技術記事や開発の記録を掲載しています"
>
  <main class="max-w-6xl mx-auto px-4 py-20">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold mb-4">ブログ</h1>
      <p class="text-xl text-base-content/70">
        開発、デザイン、テクノロジーに関する考えや学びを記録しています。
      </p>
    </div>

    <!-- Back to Home -->
    <div class="mb-8">
      <a href={import.meta.env.BASE_URL} class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        ホームに戻る
      </a>
    </div>

    <!-- Filter -->
    <FilterSection tags={allTags} containerId="blog-grid" />

    <!-- Blog Posts Grid -->
    {
      sortedPosts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-2xl text-base-content/60">
            まだ記事がありません。公開をお楽しみに！
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-grid">
          {sortedPosts.map((post) => (
            <article
              class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow"
              data-filter-tags={(post.data.tags || []).join(",")}
            >
              <figure class="aspect-video">
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover"
                  width={600}
                  height={400}
                />
              </figure>
              <div class="card-body">
                <time class="text-sm text-base-content/60">
                  {formatDate(post.data.publishDate)}
                </time>
                <h2 class="card-title hover:text-primary transition-colors">
                  <a href={`${import.meta.env.BASE_URL}blog/${post.id}`}>
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-base-content/80">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-2">
                    {post.data.tags.map((tag) => (
                      <SkillBadge
                        skill={tag}
                        href={`${import.meta.env.BASE_URL}blog?tag=${encodeURIComponent(tag.toLowerCase())}`}
                      />
                    ))}
                  </div>
                )}
                <div class="card-actions justify-end mt-4">
                  <a
                    href={`${import.meta.env.BASE_URL}blog/${post.id}`}
                    class="btn btn-primary btn-sm"
                  >
                    記事を読む
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }
  </main>
</Layout>
