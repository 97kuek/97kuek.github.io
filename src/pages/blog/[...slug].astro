---
import { getEntry, getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("blog");
  return entries.map((entry) => ({
    params: { slug: entry.id },
  }));
}

// Get the slug from params and fetch the entry
const { slug } = Astro.params;

// Handle the slug (could be "welcome-post" or "guides/markdown-guide")
const entry = await getEntry("blog", slug as string);

// If entry doesn't exist, return 404
if (!entry) {
  return Astro.redirect(`${import.meta.env.BASE_URL}404`);
}

const { Content, headings } = await render(entry);

const body = entry.body ?? '';
const japaneseChars = (body.match(/[　-鿿＀-￯]/g) ?? []).length;
const englishWords = (body.match(/[a-zA-Z]+/g) ?? []).length;
const readingTime = Math.max(1, Math.ceil(japaneseChars / 500 + englishWords / 200));

const allEntries = await getCollection("blog");
const sorted = allEntries.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const currentIndex = sorted.findIndex((e) => e.id === entry.id);
const prevEntry = sorted[currentIndex + 1];
const nextEntry = sorted[currentIndex - 1];
const base = import.meta.env.BASE_URL;
const prevNav = prevEntry ? { title: prevEntry.data.title, description: prevEntry.data.description, url: `${base}blog/${prevEntry.id}` } : undefined;
const nextNav = nextEntry ? { title: nextEntry.data.title, description: nextEntry.data.description, url: `${base}blog/${nextEntry.id}` } : undefined;
---

<BlogLayout
  id={entry.id}
  title={entry.data.title}
  description={entry.data.description}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  image={entry.data.image}
  tags={entry.data.tags}
  headings={headings}
  readingTime={readingTime}
  prev={prevNav}
  next={nextNav}
>
  <Content />
</BlogLayout>
