---
import Layout from "../layouts/Layout.astro";
import Terminal from "../components/Terminal.astro";
---

<Layout
  title="検索 - 植木敬太郎"
  description="ブログ記事・プロジェクトを検索"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>

  <main id="main-content" class="max-w-3xl mx-auto px-4 py-20">
    <div class="text-center mb-10">
      <p class="text-sm font-bold tracking-widest text-primary uppercase mb-3">SEARCH</p>
      <h1 class="text-3xl font-bold mb-2">検索</h1>
      <p class="text-base text-base-content/60">ブログ記事やプロジェクトを検索できます</p>
    </div>

    <Terminal title="keitaro@portfolio:~/search — pagefind">
      <p class="search-prompt">
        <span class="g">keitaro@portfolio</span><span class="muted">:</span><span class="b">~/search</span><span class="muted">$</span> pagefind --query
      </p>
      <div id="search"></div>
    </Terminal>
  </main>
</Layout>

<style>
  .search-prompt {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
  }
  .search-prompt .g {
    color: #27c93f;
  }
  .search-prompt .b {
    color: #e0986a;
  }
  .search-prompt .muted {
    color: #8b949e;
  }
</style>

<style is:global>
  #search {
    --pagefind-ui-primary: #e0986a;
    --pagefind-ui-text: #e1e4e8;
    --pagefind-ui-background: #1f2428;
    --pagefind-ui-border: #30363d;
    --pagefind-ui-tag: #24292e;
    --pagefind-ui-font: "JetBrains Mono", "Fira Code", Consolas, monospace;
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-border-width: 1px;
  }
  #search .pagefind-ui__search-input {
    /* iOS Safari renders text/search inputs with its own white, rounded,
       shadowed chrome unless appearance is reset — without this the field
       stayed light on iPhone/iPad and broke the terminal look. */
    -webkit-appearance: none;
    appearance: none;
    background: #0d1117;
    color: #e1e4e8;
    caret-color: #27c93f;
    /* 16px keeps iOS Safari from auto-zooming the page on focus. */
    font-size: 16px;
  }
  #search .pagefind-ui__search-input::placeholder {
    color: #6e7681;
  }
  #search .pagefind-ui__search-clear {
    color: #8b949e;
    background: transparent;
  }
  #search .pagefind-ui__message {
    color: #8b949e;
  }
  #search .pagefind-ui__message::before {
    content: "→ ";
    color: #27c93f;
  }
  #search .pagefind-ui__result {
    border-color: #30363d;
  }
  #search .pagefind-ui__result-link {
    color: #e0986a;
  }
  #search .pagefind-ui__result-excerpt {
    color: #c9d1d9;
  }
  #search .pagefind-ui__result-excerpt mark,
  #search mark {
    background: #bb800944;
    color: #ffe9b3;
  }
  #search .pagefind-ui__button {
    color: #e1e4e8;
    border-color: #30363d;
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', function () {
    if (!document.getElementById('search')) return;
    var script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = function () {
      new PagefindUI({
        element: '#search',
        showImages: false,
        showEmptyFilters: false,
      });
    };
    script.onerror = function () {
      var el = document.getElementById('search');
      if (el) {
        el.innerHTML =
          '<p style="text-align:center;color:#8b949e;padding:2rem 0">開発環境では検索を使用できません。<br><code style="font-size:0.875rem">npm run build &amp;&amp; npm run preview</code> をお試しください。</p>';
      }
    };
    document.head.appendChild(script);
  });
</script>
