---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="検索 - 植木敬太郎"
  description="ブログ記事・プロジェクトを検索"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>

  <main id="main-content" class="max-w-3xl mx-auto px-4 py-20">
    <div class="text-center mb-12">
      <p class="text-sm font-bold tracking-widest text-primary uppercase mb-3">SEARCH</p>
      <h1 class="text-3xl font-bold mb-4">検索</h1>
      <p class="text-base text-base-content/60">ブログ記事やプロジェクトを検索できます</p>
    </div>

    <div id="search"></div>
  </main>
</Layout>

<style>
  #search {
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-base-content);
    --pagefind-ui-background: var(--color-base-100);
    --pagefind-ui-border: var(--color-base-300);
    --pagefind-ui-tag: var(--color-base-200);
    --pagefind-ui-font: inherit;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-border-width: 1px;
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', function () {
    if (!document.getElementById('search')) return;
    var script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = function () {
      new PagefindUI({
        element: '#search',
        showImages: false,
        showEmptyFilters: false,
      });
    };
    script.onerror = function () {
      var el = document.getElementById('search');
      if (el) {
        el.innerHTML =
          '<p style="text-align:center;color:#718096;padding:3rem 0">開発環境では検索を使用できません。<br><code style="font-size:0.875rem">npm run build &amp;&amp; npm run preview</code> をお試しください。</p>';
      }
    };
    document.head.appendChild(script);
  });
</script>
