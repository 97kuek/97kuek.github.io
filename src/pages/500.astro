---
import Layout from "../layouts/Layout.astro";
import { House, ArrowLeft } from "@lucide/astro";

interface Props {
  error?: unknown;
}

const { error } = Astro.props;

// Sanitize error for display - NEVER expose sensitive server details in production
const displayMessage =
  "An unexpected error occurred while processing your request.";

// Log full error server-side for debugging (only visible in server logs)
if (error instanceof Error) {
  console.error("500 Server Error:", {
    message: error.message,
    stack: error.stack,
    timestamp: new Date().toISOString(),
  });
}
---

<Layout
  title="500 - サーバーエラー"
  description="リクエストの処理中にエラーが発生しました。"
>
  <div class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-2xl mx-auto">
      <!-- Large 500 Number -->
      <h1 class="text-9xl font-bold text-error mb-4 animate-pulse">500</h1>

      <!-- Error Title -->
      <h2 class="text-4xl font-bold mb-4">サーバーエラー</h2>

      <!-- Error Description -->
      <p class="text-xl mb-8 text-base-content/70">
        予期しないエラーが発生しました。
        <br />
        しばらく経ってから再度お試しください。
      </p>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Action Buttons -->
      <div class="flex gap-4 justify-center flex-wrap mt-8">
        <a href={import.meta.env.BASE_URL} class="btn btn-primary gap-2">
          <House class="size-5" />
          ホームに戻る
        </a>
        <button type="button" onclick="history.back()" class="btn btn-outline gap-2">
          <ArrowLeft class="size-5" />
          前のページへ
        </button>
      </div>

      <!-- Helpful Links -->
      <div class="mt-12">
        <p class="text-sm text-base-content/60 mb-4">お困りですか？</p>
        <div class="flex gap-3 justify-center flex-wrap text-sm">
          <a
            href={`${import.meta.env.BASE_URL}#contact`}
            class="link link-hover">お問い合わせ</a
          >
          <span class="text-base-content/30">&bull;</span>
          <a
            href="https://github.com/97kuek/97kuek.github.io/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="link link-hover">問題を報告</a
          >
        </div>
      </div>
    </div>
  </div>
</Layout>
