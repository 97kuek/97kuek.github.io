---
import Layout from "../layouts/Layout.astro";
import { House, ArrowLeft } from "@lucide/astro";
import { useTranslations, type Lang } from "../i18n/ui";
import { SITE } from "../utils/site";

interface Props {
  error?: unknown;
}

const { error } = Astro.props;
const locale = (Astro.currentLocale ?? "ja") as Lang;
const t = useTranslations(locale);

// Log full error server-side for debugging (only visible in server logs)
if (error instanceof Error) {
  console.error("500 Server Error:", {
    message: error.message,
    stack: error.stack,
    timestamp: new Date().toISOString(),
  });
}
---

<Layout
  title={`500 - ${t("500.title")}`}
  description={t("500.description")}
>
  <div class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-2xl mx-auto">
      <!-- Large 500 Number -->
      <h1 class="text-9xl font-bold text-error mb-4 animate-bounce">500</h1>

      <!-- Error Title -->
      <h2 class="text-4xl font-bold mb-4">{t("500.heading")}</h2>

      <!-- Error Description -->
      <p class="text-xl mb-8 text-base-content/70">
        {t("500.message")}
        <br />
        {t("500.retry")}
      </p>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Action Buttons -->
      <div class="flex gap-4 justify-center flex-wrap mt-8">
        <a href={import.meta.env.BASE_URL} class="btn btn-primary gap-2">
          <House class="size-5" />
          {t("404.backHome")}
        </a>
        <button type="button" onclick="history.back()" class="btn btn-outline gap-2">
          <ArrowLeft class="size-5" />
          {t("500.back")}
        </button>
      </div>

      <!-- Helpful Links -->
      <div class="mt-12">
        <p class="text-sm text-base-content/60 mb-4">{t("500.help")}</p>
        <div class="flex gap-3 justify-center flex-wrap text-sm">
          <a
            href={`${import.meta.env.BASE_URL}#contact`}
            class="link link-hover">{t("404.contact")}</a
          >
          <span class="text-base-content/30">&bull;</span>
          <a
            href={`https://github.com/${SITE.repository}/issues`}
            target="_blank"
            rel="noopener noreferrer"
            class="link link-hover">{t("500.report")}</a
          >
        </div>
      </div>
    </div>
  </div>
</Layout>
