---
import { getEntry, getCollection, render } from "astro:content";
import ProjectLayout from "../../layouts/ProjectLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map((entry) => ({
    params: { slug: entry.id },
  }));
}

// Get the slug from params and fetch the entry
const { slug } = Astro.params;

// Handle the slug
const entry = await getEntry("projects", slug as string);

// If entry doesn't exist, return 404
if (!entry) {
  return Astro.redirect(`${import.meta.env.BASE_URL}404`);
}

const { Content } = await render(entry);

const allProjects = await getCollection("projects");
const sorted = allProjects.sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
const currentIndex = sorted.findIndex((e) => e.id === entry.id);
const prevEntry = sorted[currentIndex + 1];
const nextEntry = sorted[currentIndex - 1];
const base = import.meta.env.BASE_URL;
const prevNav = prevEntry ? { title: prevEntry.data.title, description: prevEntry.data.description, url: `${base}projects/${prevEntry.id}` } : undefined;
const nextNav = nextEntry ? { title: nextEntry.data.title, description: nextEntry.data.description, url: `${base}projects/${nextEntry.id}` } : undefined;
---

<ProjectLayout
  id={entry.id}
  title={entry.data.title}
  description={entry.data.description}
  startDate={entry.data.startDate}
  endDate={entry.data.endDate}
  image={entry.data.image}
  skills={entry.data.skills}
  demoLink={entry.data.demoLink}
  sourceLink={entry.data.sourceLink}
  updatedDate={entry.data.updatedDate}
  prev={prevNav}
  next={nextNav}
>
  <Content />
</ProjectLayout>
