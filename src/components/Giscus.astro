---
// Giscus.astro
const isEn = (Astro.currentLocale ?? "ja") === "en";
const commentsTitle = isEn ? "Comments" : "コメント";
const commentsDescription = isEn
    ? "GitHub Discussions comments are loaded only when you open them."
    : "GitHub Discussions のコメント欄は、開いたときだけ読み込みます。";
const commentsButton = isEn ? "Load comments" : "コメントを読み込む";
---

<div class="giscus-container mt-16 max-w-4xl mx-auto px-4 w-full">
    <div class="border border-base-200 rounded-lg bg-base-100 p-5 text-center" data-giscus-placeholder>
        <h2 class="text-sm font-bold tracking-widest text-primary uppercase mb-2">{commentsTitle}</h2>
        <p class="text-sm text-base-content/60 mb-4">{commentsDescription}</p>
        <button class="btn btn-soft btn-sm" type="button" data-giscus-load>{commentsButton}</button>
    </div>
    <div class="giscus"></div>
    <script is:inline>
        let giscusLoaded = false;

        function getGiscusTheme() {
            const theme = document.documentElement.getAttribute('data-theme') || localStorage.getItem('theme');
            const darkThemes = ['dark', 'synthwave', 'dim', 'halloween', 'night', 'coffee', 'luxury'];
            return darkThemes.includes(theme) ? 'dark' : 'light';
        }

        function loadGiscus() {
            if (giscusLoaded || document.querySelector('iframe.giscus-frame')) return;
            const theme = getGiscusTheme();
            const script = document.createElement('script');
            script.src = 'https://giscus.app/client.js';
            script.setAttribute('data-repo', '97kuek/97kuek.github.io');
            script.setAttribute('data-repo-id', 'R_kgDORh6lYA');
            script.setAttribute('data-category', 'General');
            script.setAttribute('data-category-id', 'DIC_kwDORh6lYM4C3_9j');
            script.setAttribute('data-mapping', 'pathname');
            script.setAttribute('data-strict', '0');
            script.setAttribute('data-reactions-enabled', '1');
            script.setAttribute('data-emit-metadata', '0');
            script.setAttribute('data-input-position', 'bottom');
            script.setAttribute('data-theme', theme);
            script.setAttribute('data-lang', 'ja');
            script.setAttribute('crossorigin', 'anonymous');
            script.async = true;
            
            const container = document.querySelector('.giscus');
            if (container) {
                document.querySelector('[data-giscus-placeholder]')?.remove();
                container.appendChild(script);
                giscusLoaded = true;
            }
        }

        function updateGiscusTheme() {
            const theme = getGiscusTheme();
            const iframe = document.querySelector('iframe.giscus-frame');
            if (iframe && iframe.contentWindow) {
                iframe.contentWindow.postMessage(
                    { giscus: { setConfig: { theme } } },
                    'https://giscus.app'
                );
            }
        }

        // Listen for theme changes from the site's theme toggle
        let observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
                    updateGiscusTheme();
                }
            });
        });

        function startObserver() {
            observer.disconnect();
            observer = new MutationObserver((mutations) => {
                mutations.forEach((mutation) => {
                    if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
                        updateGiscusTheme();
                    }
                });
            });
            observer.observe(document.documentElement, { attributes: true });
        }

        // Disconnect before page swap to prevent leaks
        document.addEventListener('astro:before-swap', () => {
            observer.disconnect();
        });

        startObserver();

        // Run on page load
        function initGiscusLoader() {
            const button = document.querySelector('[data-giscus-load]');
            if (button) {
                button.addEventListener('click', loadGiscus, { once: true });
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initGiscusLoader);
        } else {
            initGiscusLoader();
        }

        // For Astro view transitions
        document.addEventListener('astro:after-swap', () => {
            startObserver();
            initGiscusLoader();
            if (document.querySelector('iframe.giscus-frame')) {
                updateGiscusTheme();
            }
        });
    </script>
</div>
