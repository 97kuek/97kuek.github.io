---
---

<div
  id="lightbox-overlay"
  class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/85 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-label="画像拡大表示"
>
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 btn btn-circle btn-sm btn-ghost text-white hover:bg-white/20 z-10"
    aria-label="閉じる"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <img
    id="lightbox-image"
    src=""
    alt=""
    class="max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl transition-transform duration-200 scale-95 opacity-0"
  />

  <p
    id="lightbox-caption"
    class="absolute bottom-4 left-0 right-0 text-center text-white/75 text-sm px-8 pointer-events-none"
  ></p>
</div>

<script>
  const overlay = document.getElementById('lightbox-overlay')!;
  const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightbox-caption')!;
  const closeBtn = document.getElementById('lightbox-close')!;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxCaption.textContent = alt || '';
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
    // アニメーション
    requestAnimationFrame(() => {
      lightboxImg.classList.remove('scale-95', 'opacity-0');
      lightboxImg.classList.add('scale-100', 'opacity-100');
    });
  }

  function closeLightbox() {
    lightboxImg.classList.remove('scale-100', 'opacity-100');
    lightboxImg.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      document.body.style.overflow = '';
      lightboxImg.src = '';
    }, 150);
  }

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeLightbox();
  });

  closeBtn.addEventListener('click', closeLightbox);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
      closeLightbox();
    }
  });

  function initLightbox() {
    const proseImages = document.querySelectorAll<HTMLImageElement>(
      '.prose img:not([data-no-lightbox])'
    );
    proseImages.forEach((img) => {
      if (img.dataset.lightboxInit) return;
      img.dataset.lightboxInit = '1';
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        openLightbox(img.src, img.alt);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initLightbox);
  initLightbox();
</script>
