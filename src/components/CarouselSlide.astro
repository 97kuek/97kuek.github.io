---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const { src, alt = '' } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpg,jpeg,png,webp,gif,avif}',
  { eager: true }
);

let resolvedSrc: ImageMetadata | string = src;
if (src.startsWith('@assets/')) {
  const key = src.replace('@assets/', '/src/assets/');
  resolvedSrc = allImages[key]?.default ?? src;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const strSrc = typeof resolvedSrc === 'string'
  ? (resolvedSrc.startsWith('http') ? resolvedSrc : `${base}${resolvedSrc}`)
  : null;
---

<div class="carousel-slide flex-shrink-0 w-full aspect-video">
  {strSrc ? (
    <img src={strSrc} alt={alt} class="w-full h-full object-cover" />
  ) : (
    <Image
      src={resolvedSrc as ImageMetadata}
      alt={alt}
      class="w-full h-full object-cover"
      width={1200}
      height={675}
    />
  )}
</div>
