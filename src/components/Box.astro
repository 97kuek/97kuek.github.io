---
const { color, title } = Astro.props;

type BoxConfig = {
  wrapper: string;
  titleColor: string;
  icon: string;
};

const configs: Record<string, BoxConfig> = {
  info:    { wrapper: 'border-l-4 border-info bg-info/5',       titleColor: 'text-info',    icon: '💡' },
  warning: { wrapper: 'border-l-4 border-warning bg-warning/5', titleColor: 'text-warning', icon: '⚠️' },
  success: { wrapper: 'border-l-4 border-success bg-success/5', titleColor: 'text-success', icon: '✅' },
  error:   { wrapper: 'border-l-4 border-error bg-error/5',     titleColor: 'text-error',   icon: '❌' },
};

const cfg = configs[color] ?? {
  wrapper: 'border-l-4 border-base-content/25 bg-base-200/50',
  titleColor: 'text-base-content/60',
  icon: '📝',
};
---

<div class={`my-8 rounded-r-xl px-6 py-5 ${cfg.wrapper}`}>
  {title && (
    <div class={`not-prose flex items-center gap-1.5 mb-3 ${cfg.titleColor}`}>
      <span class="text-sm leading-none">{cfg.icon}</span>
      <span class="text-sm font-semibold">{title}</span>
    </div>
  )}
  <slot />
</div>
