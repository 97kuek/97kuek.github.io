---
const { color, title } = Astro.props;

const styles: Record<string, string> = {
  info: 'border-info/70 bg-info/10',
  warning: 'border-warning/70 bg-warning/10',
  success: 'border-success/70 bg-success/10',
  error: 'border-error/70 bg-error/10',
};

const colorClass = styles[color] ?? 'border-base-content/40 bg-base-200';
---

<div class={`not-prose my-8 rounded-2xl border-2 p-6 ${colorClass}`}>
  {title && <p class="mb-3 text-lg font-black text-base-content uppercase tracking-widest">{title}</p>}
  <div class="prose max-w-none">
    <slot />
  </div>
</div>
