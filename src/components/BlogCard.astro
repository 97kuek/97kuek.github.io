---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<div class="card image-full shadow-xl hover:shadow-2xl transition-shadow">
  <figure class="aspect-video">
    <Image src={post.data.image} alt={post.data.title} />
  </figure>
  <div
    class="card-body rounded-lg justify-end bg-gradient-to-t from-primary/90 via-primary/50 to-transparent"
  >
    <h3
      class="card-title text-white hover:text-primary-content transition-colors"
    >
      <a href={`${import.meta.env.BASE_URL}blog/${post.id}`}
        >{post.data.title}</a
      >
    </h3>
    <time class="text-sm text-white/80">
      {formatDate(post.data.publishDate)}
    </time>
    <p class="text-white/90 line-clamp-2">{post.data.description}</p>
  </div>
</div>
