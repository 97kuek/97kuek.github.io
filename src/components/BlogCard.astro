---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import OgPlaceholder from "./OgPlaceholder.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const body = post.body ?? '';
const japaneseChars = (body.match(/[　-鿿＀-￯]/g) ?? []).length;
const englishWords = (body.match(/[a-zA-Z]+/g) ?? []).length;
const readingTime = Math.max(1, Math.ceil(japaneseChars / 500 + englishWords / 200));
---

<a
  href={`${import.meta.env.BASE_URL}blog/${post.id}`}
  class="block group"
>
  <article class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md hover:border-primary/20 hover:-translate-y-0.5 transition-all duration-200">
    <figure class="aspect-video overflow-hidden">
      {post.data.image ? (
        <Image src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
      ) : (
        <OgPlaceholder id={post.id} title={post.data.title} tags={post.data.tags} showText={false} />
      )}
    </figure>
    <div class="card-body">
      <h3 class="card-title text-base line-clamp-2 group-hover:text-primary transition-colors">
        {post.data.title}
      </h3>
      <div class="flex items-center gap-3 text-xs text-base-content/60">
        <time>{formatDate(post.data.publishDate)}</time>
        <span>約{readingTime}分</span>
      </div>
      <p class="text-base-content/70 text-sm line-clamp-2">{post.data.description}</p>
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1 mt-1">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="text-[0.65rem] leading-none px-1.5 py-0.5 rounded-full bg-primary/10 text-primary border border-primary/20">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </article>
</a>
