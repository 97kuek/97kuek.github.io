---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import OgPlaceholder from "./OgPlaceholder.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const body = post.body ?? '';
const japaneseChars = (body.match(/[　-鿿＀-￯]/g) ?? []).length;
const englishWords = (body.match(/[a-zA-Z]+/g) ?? []).length;
const readingTime = Math.max(1, Math.ceil(japaneseChars / 500 + englishWords / 200));
---

<a
  href={`${import.meta.env.BASE_URL}blog/${post.id}`}
  class="block group"
>
  <div class="relative h-64 rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-shadow">
    <!-- Background image / placeholder -->
    <div class="absolute inset-0">
      {post.data.image ? (
        <Image src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
      ) : (
        <OgPlaceholder id={post.id} title={post.data.title} tags={post.data.tags} showText={false} />
      )}
    </div>

    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/50 to-transparent" />

    <!-- Content -->
    <div class="absolute inset-0 flex flex-col justify-end p-4 gap-1">
      <h3 class="text-base font-bold leading-snug text-white group-hover:text-primary-content transition-colors line-clamp-2">
        {post.data.title}
      </h3>
      <div class="flex items-center gap-3 text-xs text-white/70">
        <time>{formatDate(post.data.publishDate)}</time>
        <span>約{readingTime}分</span>
      </div>
      <p class="text-white/90 text-sm line-clamp-2">{post.data.description}</p>
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1 mt-1">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="text-[0.65rem] leading-none px-1.5 py-0.5 rounded-full bg-white/20 text-white/80 border border-white/25">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</a>
