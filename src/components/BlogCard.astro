---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import OgPlaceholder from "./OgPlaceholder.astro";
import { formatDate, calcReadingTime } from "../utils/formatDate";
import { useTranslations, type Lang } from "../i18n/ui";

interface Props {
  post: CollectionEntry<"blog">;
  /** h2 for list pages (under the page h1), h3 under a section h2 */
  headingLevel?: "h2" | "h3";
  /** Tag to highlight as active (used on tag pages) */
  highlightTag?: string;
}

const { post, headingLevel = "h3", highlightTag } = Astro.props;
const Heading = headingLevel;

const t = useTranslations((Astro.currentLocale ?? "ja") as Lang);

const readingTime = calcReadingTime(post.body ?? "");
const readingTimeLabel = t("blog.readingTime").replace("{n}", String(readingTime));
const tags = post.data.tags ?? [];
---

<article
  class="card bg-base-100 border border-base-200 hover:border-primary/20 transition-colors duration-200 h-full relative group"
  data-filter-tags={tags.join(",")}
>
  <figure class="aspect-video overflow-hidden flex-none">
    {post.data.image ? (
      <Image
        src={post.data.image}
        alt={post.data.title}
        class="w-full h-full object-cover"
        width={600}
        height={400}
      />
    ) : (
      <OgPlaceholder id={post.id} title={post.data.title} label="BLOG" minimal={true} />
    )}
  </figure>
  <div class="card-body">
    <div class="flex items-center gap-2 text-xs text-base-content/60">
      <time>{formatDate(post.data.publishDate)}</time>
      <span>&bull;</span>
      <span>{readingTimeLabel}</span>
    </div>
    <Heading class="card-title text-base line-clamp-2">
      <a
        href={`${import.meta.env.BASE_URL}blog/${post.id}`}
        class="group-hover:text-primary transition-colors after:absolute after:inset-0 after:content-['']"
      >{post.data.title}</a>
    </Heading>
    <p class="text-base-content/70 text-sm line-clamp-2">{post.data.description}</p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mt-1">
          {tags.slice(0, 3).map((tag) => (
            <a
              href={`${import.meta.env.BASE_URL}blog/tags/${tag}`}
              class={`text-[0.65rem] leading-none px-1.5 py-0.5 rounded-full border transition-colors relative z-10 ${
                tag === highlightTag
                  ? "bg-secondary text-secondary-content border-secondary"
                  : "bg-secondary/10 text-secondary border-secondary/20 hover:bg-secondary/20"
              }`}
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
