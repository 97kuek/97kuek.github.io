---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { FLAT_CARD_CLASS } from "../utils/classes";

interface Props {
  currentId: string;
  collection: "blog" | "projects";
  tags: string[];
  maxResults?: number;
}

const { currentId, collection, tags, maxResults = 3 } = Astro.props;

if (!tags || tags.length === 0) return null;

const isEn = (Astro.currentLocale ?? "ja") === "en";
// English pages exist for projects only; blog is Japanese-only
const collectionBase =
  isEn && collection === "projects"
    ? `${import.meta.env.BASE_URL}en/${collection}`
    : `${import.meta.env.BASE_URL}${collection}`;

const allEntries = await getCollection(collection);

// Calculate relevance score based on tag overlap
const relatedEntries = allEntries
  .filter((entry) => entry.id !== currentId)
  .map((entry) => {
    const entryTags = collection === "blog"
      ? ((entry as CollectionEntry<"blog">).data.tags ?? [])
      : ((entry as CollectionEntry<"projects">).data.skills ?? []);
    const intersection = tags.filter((tag) => entryTags.includes(tag));
    return { entry, score: intersection.length };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, maxResults);

if (relatedEntries.length === 0) return null;

const mappedEntries = relatedEntries.map(({ entry }) => {
  const data = entry.data as CollectionEntry<"blog">["data"] & {
    title_en?: string;
    description_en?: string;
  };
  return {
    entry,
    data,
    displayTitle: isEn && data.title_en ? data.title_en : data.title,
    displayDescription:
      isEn && data.description_en ? data.description_en : data.description,
  };
});
---

<section class="mt-20">
  <h2 class="text-sm font-bold tracking-widest text-primary uppercase mb-6">{collection === "blog" ? "RELATED POSTS" : "RELATED PROJECTS"}</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {
      mappedEntries.map(({ entry, data, displayTitle, displayDescription }) => (
        <a
          href={`${collectionBase}/${entry.id}`}
          class={`group block ${FLAT_CARD_CLASS} overflow-hidden`}
        >
          {data.image && (
            <figure class="aspect-video overflow-hidden">
              <Image
                src={data.image}
                alt={displayTitle}
                class="w-full h-full object-cover"
                width={400}
                height={225}
              />
            </figure>
          )}
          <div class="card-body p-4">
            <h3 class="card-title text-lg group-hover:text-primary transition-colors">
              {displayTitle}
            </h3>
            <p class="text-sm text-base-content/70 line-clamp-2">
              {displayDescription}
            </p>
          </div>
        </a>
      ))
    }
  </div>
</section>
