---
import { Plus } from "@lucide/astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  photo?: ImageMetadata | string;
  Content: any;
  link?: string;
}

const { title, photo, Content, link } = Astro.props;
---

<section id="about" class="py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="card lg:card-side bg-base-200 shadow-sm">
      {
        photo && (
          <figure class="shrink-0 lg:w-1/3 pt-8 lg:pt-0 flex justify-center">
            <div class="w-48 h-48 lg:h-full lg:w-full overflow-hidden rounded-full lg:rounded-2xl mx-auto">
              {typeof photo === "string" ? (
                <img
                  src={photo}
                  alt={title}
                  class="w-full h-full object-cover"
                />
              ) : (
                <Image
                  src={photo}
                  alt={title}
                  class="w-full h-full object-cover"
                />
              )}
            </div>
          </figure>
        )
      }
      <div class="card-body lg:p-10 justify-center">
        <h2 class="card-title text-3xl mb-2">{title}</h2>
        <article
          class="prose prose-sm lg:prose-base max-w-none prose-a:text-primary prose-a:underline prose-a:hover:opacity-80"
        >
          <Content />
        </article>
        {
          link && (
            <div class="card-actions justify-end mt-4">
              <a
                href={
                  link.startsWith("http")
                    ? link
                    : `${import.meta.env.BASE_URL}${link.startsWith("/") ? link.slice(1) : link}`
                }
                target={link.startsWith("http") ? "_blank" : "_self"}
                class="btn btn-primary"
              >
                <Plus class="size-5" />
                詳細を見る
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
