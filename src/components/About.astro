---
import { Plus } from "@lucide/astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { useTranslations, type Lang } from "../i18n/ui";

interface Props {
  title: string;
  photo?: ImageMetadata | string;
  Content: any;
  link?: string;
}

const { title, photo, Content, link } = Astro.props;
const t = useTranslations((Astro.currentLocale ?? "ja") as Lang);
---

<section id="about" class="py-16 px-4">
  <div class="max-w-5xl mx-auto">
    <!-- Section label -->
    <div class="text-center mb-10">
      <p class="text-sm font-bold tracking-widest text-primary uppercase mb-2">ABOUT</p>
    </div>

    <div class="card lg:card-side bg-base-100 border border-base-200 overflow-hidden">
      {
        photo && (
          <figure class="shrink-0 lg:w-1/3 pt-8 lg:pt-0 flex justify-center">
            <div class="w-56 h-56 lg:h-full lg:w-full overflow-hidden rounded-full lg:rounded-none mx-auto ring-4 ring-primary/30 lg:ring-0">
              {typeof photo === "string" ? (
                <img
                  src={photo}
                  alt={title}
                  class="w-full h-full object-cover"
                />
              ) : (
                <Image
                  src={photo}
                  alt={title}
                  class="w-full h-full object-cover"
                />
              )}
            </div>
          </figure>
        )
      }
      <div class="card-body lg:p-10 justify-center">
        <h2 class="card-title text-3xl lg:text-4xl mb-2">{title}</h2>
        <article
          class="prose prose-base max-w-none prose-a:text-primary prose-a:underline prose-a:hover:opacity-80"
        >
          <Content />
        </article>
        {
          link && (
            <div class="card-actions justify-end mt-4">
              <a
                href={
                  link.startsWith("http")
                    ? link
                    : `${import.meta.env.BASE_URL}${link.startsWith("/") ? link.slice(1) : link}`
                }
                target={link.startsWith("http") ? "_blank" : "_self"}
                class="btn btn-primary"
              >
                <Plus class="size-5" />
                {t("about.seeMore")}
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
