---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import { ArrowRight, FolderGit2 } from "@lucide/astro";

const projectEntries = await getCollection("projects");

const featuredProjects = projectEntries
  .filter((project) => project.data.featured === true)
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime())
  .slice(0, 3);
---

<section id="projects" class="py-24 px-4 bg-base-100">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-semibold mb-4">
        <FolderGit2 class="size-3.5" />
        PROJECTS
      </div>
      <div class="w-16 h-1 bg-gradient-to-r from-[#4f46e5] to-[#7c3aed] rounded-full mx-auto mb-4"></div>
      <p class="text-lg text-base-content/65">
        Webアプリから画像処理プログラムまで、これまで取り組んできたプロジェクトの一部をご紹介します。
      </p>
    </div>

    {
      featuredProjects.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-lg text-base-content/60">
            注目のプロジェクトはまだありません。すべてのプロジェクトをご覧ください。
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      )
    }

    <div class="text-center mt-10">
      <a href={`${import.meta.env.BASE_URL}projects`} class="btn btn-primary btn-outline gap-2">
        すべてのプロジェクトを見る
        <ArrowRight class="size-4" />
      </a>
    </div>
  </div>
</section>
