---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import { ArrowRight } from "@lucide/astro";

const projectEntries = await getCollection("projects");

const featuredProjects = projectEntries
  .filter((project) => project.data.featured === true)
  .sort((a, b) => {
    const aTime = a.data.endDate ? a.data.endDate.getTime() : Number.MAX_SAFE_INTEGER;
    const bTime = b.data.endDate ? b.data.endDate.getTime() : Number.MAX_SAFE_INTEGER;
    return bTime - aTime;
  })
  .slice(0, 3);
---

<section id="projects" class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-sm font-bold tracking-widest text-primary uppercase mb-3">PROJECTS</p>
      <p class="text-lg text-base-content/60">
        Webアプリから画像処理プログラムまで、これまで取り組んできたプロジェクトの一部をご紹介します。
      </p>
    </div>

    {
      featuredProjects.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-lg text-base-content/60">
            注目のプロジェクトはまだありません。すべてのプロジェクトをご覧ください。
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      )
    }

    <div class="text-center mt-10">
      <a href={`${import.meta.env.BASE_URL}projects`} class="btn btn-primary btn-outline gap-2">
        すべてのプロジェクトを見る
        <ArrowRight class="size-4" />
      </a>
    </div>
  </div>
</section>
