---
import { getCollection, getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { ExternalLink } from "@lucide/astro";
import SkillBadge from "./SkillBadge.astro";
import FilterSection from "./FilterSection.astro";
import { useTranslations, type Lang } from "../i18n/ui";
import { formatPeriod, calculateDuration } from "../utils/formatDate";

interface Props {
  collection: "work" | "education";
  variant: "timeline" | "list";
  color?: string;
  backgroundColor?: string;
  icon: any;
  sectionTitle: string;
  sectionSubtitle?: string;
}

const {
  collection,
  variant,
  color = "primary",
  backgroundColor = "base-200",
  icon,
  sectionTitle,
  sectionSubtitle,
} = Astro.props;

const IconComponent = icon;
const locale = (Astro.currentLocale ?? "ja") as Lang;
const t = useTranslations(locale);

const allEntries = await getCollection(collection);
const entries = allEntries.filter((entry) =>
  locale === "en" ? entry.id.endsWith("-en") : !entry.id.endsWith("-en")
);

const aboutId = locale === "en" ? "en" : "index";
const aboutEntry = (await getEntry("about", aboutId as any))!;
const aboutLink = aboutEntry?.data?.link;

const sortedEntries = entries.sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime()
);

const dateLocale = t("timeline.dateLocale");
const presentText = t("timeline.present");
const monthsLabel = t("timeline.months");
const yearsLabel = t("timeline.years");

const entriesWithContent = await Promise.all(
  sortedEntries.map(async (entry) => {
    const { Content } = await render(entry);
    const period = formatPeriod(entry.data.startDate, entry.data.endDate, dateLocale, presentText);
    const duration = calculateDuration(entry.data.startDate, entry.data.endDate, monthsLabel, yearsLabel);
    return { entry, Content, period, duration };
  })
);

const workEntries = entries as CollectionEntry<"work">[];

const allSkills =
  collection === "work"
    ? [...new Set(workEntries.flatMap((e) => e.data.skills || []))].sort()
    : [];

const skillCounts =
  collection === "work"
    ? workEntries.reduce(
        (acc, entry) => {
          (entry.data.skills || []).forEach((skill: string) => {
            acc[skill] = (acc[skill] || 0) + 1;
          });
          return acc;
        },
        {} as Record<string, number>
      )
    : {};

const containerId = `${collection}-items`;
---

<section id={collection} class={`py-16 px-4 bg-${backgroundColor}`}>
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-bold tracking-widest text-primary uppercase mb-2">{sectionTitle}</p>
      {sectionSubtitle && (
        <p class="text-base text-base-content/60 mt-1">{sectionSubtitle}</p>
      )}
    </div>

    {collection === "work" && allSkills.length > 0 && (
      <div class="flex justify-center">
        <FilterSection tags={allSkills} tagCounts={skillCounts} totalCount={entries.length} containerId={containerId} />
      </div>
    )}

    {variant === "timeline" ? (
      <ul class="timeline timeline-vertical timeline-snap-icon timeline-compact" id={containerId}>
        {entriesWithContent.map(({ entry, Content, period, duration }, index) => (
          <li data-filter-tags={(collection === "work" ? ((entry as CollectionEntry<"work">).data.skills || []) : []).join(",")}>
            {index > 0 && <hr class="bg-base-100" />}
            <div class="timeline-middle">
              <IconComponent class="size-5 mx-3 my-1" style={`color: var(--color-${color})`} />
            </div>
            <div class="timeline-end max-w-lg pt-3 mb-10">
              <time class="font-mono text-sm text-base-content/70 block italic">
                {period}
                {duration && <span class="ml-1 text-base-content/50">{duration}</span>}
              </time>
              <div class="card bg-base-100 border border-base-200 hover:border-primary/20 transition-colors duration-200 mt-2">
                <div class="card-body gap-3">
                  <!-- Header: logo + info + link -->
                  <div class="flex items-start gap-3">
                    {entry.data.logo && (
                      <div class="avatar shrink-0">
                        <div class="w-11 mask mask-squircle">
                          <Image src={entry.data.logo} alt={entry.data.title} inferSize={true} />
                        </div>
                      </div>
                    )}
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2">
                        <div>
                          <h3 class="font-bold text-base leading-snug">{entry.data.title}</h3>
                          <p class="font-semibold text-sm mt-0.5" style={`color: var(--color-${color})`}>
                            {entry.data.subtitle}
                          </p>
                          {"location" in entry.data && entry.data.location && (
                            <p class="text-xs text-base-content/50 mt-0.5">{entry.data.location}</p>
                          )}
                        </div>
                        {entry.data.link && (
                          <a
                            href={entry.data.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn btn-ghost btn-xs gap-1 shrink-0 mt-0.5"
                          >
                            <ExternalLink class="size-3" />
                            <span class="hidden sm:inline text-xs">
                              {collection === "work" ? t("timeline.companySite") : t("timeline.schoolSite")}
                            </span>
                          </a>
                        )}
                      </div>
                    </div>
                  </div>

                  <!-- Skills -->
                  {"skills" in entry.data && entry.data.skills && entry.data.skills.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {(entry.data.skills as string[]).map((skill: string) => (
                        <SkillBadge skill={skill} />
                      ))}
                    </div>
                  )}

                  <!-- Content -->
                  <div class="prose prose-sm max-w-none text-base-content/80">
                    <Content />
                  </div>
                </div>
              </div>
            </div>
            {index < entriesWithContent.length - 1 && <hr class="bg-base-100" />}
          </li>
        ))}
      </ul>
    ) : (
      <ul class="list bg-base-100 rounded-box border border-base-200 shadow-sm">
        {entriesWithContent.map(({ entry, Content, period, duration }) => (
          <li class="border-b hover:opacity-85 transition-opacity border-base-300 last:border-b-0">
            <details class="collapse">
              <summary class="collapse-title pe-2 sm:pe-5">
                <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 w-full">
                  <div class="flex items-center gap-3 sm:gap-4 flex-1">
                    {entry.data.logo && (
                      <div class="avatar shrink-0">
                        <div class="w-10 mask mask-squircle">
                          <Image src={entry.data.logo} alt={entry.data.title} inferSize={true} />
                        </div>
                      </div>
                    )}
                    <div class="min-w-0">
                      <h3 class="font-bold text-lg leading-tight mb-1">{entry.data.title}</h3>
                      <p style={`color: var(--color-${color})`} class="font-semibold text-sm">
                        {entry.data.subtitle}
                      </p>
                    </div>
                  </div>
                  <div class="text-xs sm:text-sm text-base-content/70 font-mono sm:whitespace-nowrap shrink-0 pl-13 sm:pl-0">
                    {period}
                    {duration && <span class="ml-1 text-base-content/50">{duration}</span>}
                  </div>
                </div>
              </summary>
              <div class="collapse-content">
                <div class="prose prose-sm max-w-none">
                  <Content />
                </div>
                {entry.data.link && (
                  <div class="flex justify-end mt-2">
                    <a
                      href={entry.data.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="link link-hover text-sm"
                    >
                      {collection === "work" ? t("timeline.companySite") : t("timeline.schoolSite")}
                    </a>
                  </div>
                )}
              </div>
            </details>
          </li>
        ))}
      </ul>
    )}

    {collection === "work" && variant === "timeline" && aboutLink && (
      <div class="text-center mt-10">
        <a
          href={aboutLink}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-outline"
        >
          {t("timeline.seeResume")}
        </a>
      </div>
    )}
  </div>
</section>
