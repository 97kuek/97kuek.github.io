---
import { getCollection } from "astro:content";
import BlogCard from "./BlogCard.astro";
import { ArrowRight, BookOpen } from "@lucide/astro";

const blogEntries = await getCollection("blog");

const sortedPosts = blogEntries.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const latestPosts = sortedPosts.slice(0, 3);
---

<section id="blog" class="py-24 px-4 bg-base-200">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-semibold mb-4">
        <BookOpen class="size-3.5" />
        BLOG
      </div>
      <div class="w-16 h-1 bg-gradient-to-r from-[#4f46e5] to-[#7c3aed] rounded-full mx-auto mb-4"></div>
      <p class="text-lg text-base-content/65">
        技術的な知見や開発の裏側、日々の学びを記録しています。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestPosts.map((post) => <BlogCard post={post} />)}
    </div>

    <div class="text-center mt-12">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-primary btn-outline gap-2">
        すべての記事を見る
        <ArrowRight class="size-4" />
      </a>
    </div>
  </div>
</section>
