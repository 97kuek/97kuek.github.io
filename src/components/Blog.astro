---
import { getCollection } from "astro:content";
import BlogCard from "./BlogCard.astro";
import { ArrowRight } from "@lucide/astro";
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHeader from "./SectionHeader.astro";

const t = useTranslations((Astro.currentLocale ?? "ja") as Lang);

const blogEntries = await getCollection("blog");

const sortedPosts = blogEntries.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const latestPosts = sortedPosts.slice(0, 3);
---

<section id="blog" class="py-16 px-4 bg-base-200">
  <div class="max-w-6xl mx-auto">
    <SectionHeader label="BLOG" subtitle={t("blog.subtitle")} />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.map((post) => <BlogCard post={post} />)}
    </div>

    <div class="text-center mt-12">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-primary btn-outline gap-2">
        {t("blog.seeAll")}
        <ArrowRight class="size-4" />
      </a>
    </div>
  </div>
</section>
