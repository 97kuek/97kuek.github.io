---
import { renderToString } from 'katex';

const rawFormula = await Astro.slots.render("default");
// Markdoc sometimes wraps the formula in <p> tags, which breaks KaTeX
const formula = rawFormula.replace(/<[^>]*>/g, "").trim();
const html = renderToString(formula, {
  displayMode: true,
  throwOnError: false
});
---

<div class="katex-block my-8" set:html={html} />
