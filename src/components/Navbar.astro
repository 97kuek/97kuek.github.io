---
import { getEntry } from "astro:content";
import { useTranslations, type Lang } from "../i18n/ui";

const heroEntry = await getEntry("hero", "index");
const name = heroEntry?.data?.name ?? "Portfolio";

const base = import.meta.env.BASE_URL;
const { pathname } = Astro.url;
const locale = (Astro.currentLocale ?? "ja") as Lang;
const t = useTranslations(locale);

const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const isHome =
  pathname === base ||
  pathname === normalizedBase ||
  pathname === "/" ||
  pathname === "/en" ||
  pathname === "/en/";

const homeNavLinks = [
  { href: "#about", label: "About" },
  { href: "#projects", label: "Projects" },
  ...(locale === "ja" ? [{ href: "#blog", label: "Blog" }] : []),
  { href: "#github", label: "GitHub" },
  { href: "#work", label: "Work" },
  { href: "#education", label: "Education" },
  { href: "#contact", label: "Contact" },
];

const nonHomeNavLinks = [
  { href: locale === "en" ? "/en/" : base, label: t("nav.home") },
  ...(locale === "ja" ? [{ href: `${base}blog`, label: "Blog" }] : []),
  { href: locale === "en" ? `${base}en/projects` : `${base}projects`, label: "Projects" },
];

const navLinks = isHome ? homeNavLinks : nonHomeNavLinks;

const langToggleHref = locale === "en" ? "/" : "/en/";
const searchHref = locale === "en" ? `${base}en/search` : `${base}search`;
---

<header
  id="site-navbar"
  class="fixed top-0 left-0 right-0 z-40 navbar bg-base-100/70 backdrop-blur-md border-b border-base-200/60 transition-shadow duration-200"
>
  <div class="navbar-start">
    <a href={locale === "en" ? "/en/" : base} class="btn btn-ghost font-bold text-base">{name}</a>
  </div>

  <div class="navbar-end">
    <!-- デスクトップ: 横並びリンク -->
    <nav class="hidden lg:flex gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="btn btn-ghost btn-sm text-base-content/70 hover:text-base-content data-[active]:text-primary data-[active]:font-semibold"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- 言語トグル -->
    <a
      href={langToggleHref}
      class="btn btn-ghost btn-sm font-mono text-xs"
      aria-label={t("lang.switchLabel")}
    >
      {t("lang.switchTo")}
    </a>

    <!-- 検索ボタン -->
    <a href={searchHref} class="btn btn-ghost btn-square btn-sm" aria-label={t("nav.search")}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
    </a>

    <!-- モバイル・タブレット: ハンバーガー -->
    <div class="dropdown dropdown-end lg:hidden">
      <button tabindex="0" class="btn btn-ghost btn-square" aria-label={t("nav.openMenu")}>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>
      <ul
        tabindex="0"
        class="dropdown-content menu bg-base-100 rounded-box z-50 w-48 p-2 shadow-lg border border-base-200 mt-2"
      >
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="text-base-content/80">
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a href={langToggleHref} class="text-base-content/80 font-mono text-xs">
            {t("lang.switchTo")}
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const initNavbar = () => {
    const navbar = document.getElementById('site-navbar');
    if (!navbar) return;

    const handlers: Array<() => void> = [];

    const onScroll = () => {
      if (window.scrollY > 10) {
        navbar.classList.add('bg-base-100/95', 'shadow-sm');
        navbar.classList.remove('bg-base-100/70');
      } else {
        navbar.classList.remove('bg-base-100/95', 'shadow-sm');
        navbar.classList.add('bg-base-100/70');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    handlers.push(() => window.removeEventListener('scroll', onScroll));
    onScroll();

    const navLinks = navbar.querySelectorAll<HTMLAnchorElement>('nav a[href^="#"]');

    if (navLinks.length > 0) {
      const ids = [...navLinks].map(l => l.getAttribute('href')!.slice(1));

      const update = () => {
        const y = window.scrollY + 120;
        let current = ids[0];
        for (const id of ids) {
          const el = document.getElementById(id);
          if (el && el.offsetTop <= y) current = id;
        }
        navLinks.forEach(l => {
          if (l.getAttribute('href') === `#${current}`) {
            l.setAttribute('data-active', '');
          } else {
            l.removeAttribute('data-active');
          }
        });
      };

      window.addEventListener('scroll', update, { passive: true });
      handlers.push(() => window.removeEventListener('scroll', update));
      update();
    }

    // daisyUI dropdown stays open via focus: blur after tapping a menu item
    navbar.querySelectorAll<HTMLAnchorElement>('.dropdown a').forEach((a) => {
      a.addEventListener('click', () => {
        (document.activeElement as HTMLElement | null)?.blur();
      });
    });

    return () => handlers.forEach((off) => off());
  };

  let cleanup: (() => void) | undefined;

  const init = () => {
    cleanup = initNavbar() ?? undefined;
  };

  init();
  document.addEventListener('astro:before-swap', () => cleanup?.());
  document.addEventListener('astro:after-swap', init);
</script>
