---
import { getEntry, render } from "astro:content";
import { getIcon } from "../utils/iconMapper";

const locale = Astro.currentLocale ?? "ja";
const contactId = locale === "en" ? "en" : "index";
const contactEntry = (await getEntry("contact", contactId as any))!;
const contact = contactEntry.data;
const { Content } = await render(contactEntry);

const SectionIcon = getIcon(contact.icon);
const FooterIcon = getIcon(contact.footerIcon);

const base = import.meta.env.BASE_URL;
const isEn = locale === "en";
const footerLinks = [
  { href: isEn ? "/en/" : base, label: isEn ? "Home" : "ホーム" },
  ...(isEn ? [] : [{ href: `${base}blog`, label: "Blog" }]),
  { href: isEn ? `${base}en/projects` : `${base}projects`, label: "Projects" },
  { href: isEn ? `${base}en/search` : `${base}search`, label: isEn ? "Search" : "検索" },
  { href: `${base}rss.xml`, label: "RSS" },
];
---

<footer id="contact" class="footer footer-horizontal footer-center bg-base-200 py-10">
  <nav class="flex flex-wrap gap-x-6 gap-y-2 justify-center" aria-label={isEn ? "Footer" : "フッターナビゲーション"}>
    {footerLinks.map((link) => (
      <a href={link.href} class="link link-hover text-sm text-base-content/70 hover:text-base-content">
        {link.label}
      </a>
    ))}
  </nav>
  <aside>
    <SectionIcon class="inline-block size-14" />
    <p class="max-w-xl m-auto text-lg">
      <Content />
      <a
        href={contact.linkUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="link link-hover text-primary"
      >
        {contact.linkText}
      </a>
    </p>
    <p class="flex items-center space-x-1 text-base-content/60">
      <span>Copyright &copy; {new Date().getFullYear()} - {contact.footerText}</span
      >
      <a
        class="link link-hover inline-flex justify-center items-center"
        href={contact.footerLinkUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <FooterIcon class="size-3 inline-block mr-1" />
        {contact.footerLinkText}
      </a>
    </p>
  </aside>
</footer>
