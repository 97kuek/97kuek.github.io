---
import { Github, ArrowRight } from "@lucide/astro";
import SectionHeader from "./SectionHeader.astro";
import { FLAT_CARD_CLASS } from "../utils/classes";
import { SITE } from "../utils/site";
import { useTranslations, type Lang } from "../i18n/ui";

const USERNAME = SITE.githubUsername;
const PROFILE_URL = `https://github.com/${USERNAME}`;
// 3D contribution graph generated in the GitHub profile repository (97kuek/97kuek)
const GRAPH_3D = `https://raw.githubusercontent.com/${USERNAME}/${USERNAME}/main/profile-3d-contrib/profile-season-animate.svg`;

const t = useTranslations((Astro.currentLocale ?? "ja") as Lang);
---

<section id="github" class="py-16 px-4 bg-base-200">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      label="GITHUB"
      subtitle={t("github.subtitle")}
      subtitleClass="text-base text-base-content/60"
    />

    <div
      class={FLAT_CARD_CLASS}
    >
      <div class="card-body items-center">
        <img
          src={GRAPH_3D}
          alt="GitHub 3D contribution graph"
          loading="lazy"
          width="1280"
          height="850"
          class="w-full max-w-3xl h-auto"
        />
      </div>
    </div>

    <div class="text-center mt-12">
      <a
        href={PROFILE_URL}
        target="_blank"
        rel="noopener"
        class="btn btn-primary btn-outline gap-2"
      >
        <Github class="size-4" />
        {t("github.view")}
        <ArrowRight class="size-4" />
      </a>
    </div>
  </div>
</section>
