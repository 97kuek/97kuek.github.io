---
import { Code } from 'astro-expressive-code/components';

const { content, language: rawLanguage = 'plaintext', ...rest } = Astro.props;
const slotHtml = await Astro.slots.render("default");
const code = content || slotHtml.replace(/<[^>]*>/g, "").replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&amp;/g, '&').trim();
const lang = (rawLanguage || 'plaintext').split(/\s+/)[0] || 'plaintext';
---

<Code code={code} lang={lang} {...rest} />
