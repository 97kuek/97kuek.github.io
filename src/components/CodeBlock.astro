---
import { Code } from 'astro-expressive-code/components';

const { content, language, ...rest } = Astro.props;
const slotHtml = await Astro.slots.render("default");
// If content is empty, try to get it from slot and clean it up
const code = content || slotHtml.replace(/<[^>]*>/g, "").replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&amp;/g, '&').trim();
---

<Code code={code} lang={language || 'plaintext'} {...rest} />
