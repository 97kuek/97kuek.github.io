---
interface Props {
  tags: string[];
  containerId: string;
}

const { tags, containerId } = Astro.props;
---

<div class="flex flex-wrap gap-2 mb-8" id={`filter-${containerId}`}>
  <button
    class="btn btn-sm btn-primary filter-btn active"
    data-tag="all"
  >
    All
  </button>
  {
    tags.map((tag) => (
      <button
        class="btn btn-sm btn-outline btn-ghost filter-btn"
        data-tag={tag.toLowerCase()}
      >
        {tag}
      </button>
    ))
  }
</div>

<script define:vars={{ containerId }}>
  const initFilter = () => {
    const filterSection = document.getElementById(`filter-${containerId}`);
    const container = document.getElementById(containerId);
    
    if (filterSection && container) {
      const buttons = filterSection.querySelectorAll('.filter-btn');
      const items = container.querySelectorAll('[data-filter-tags]');

      const filterByTag = (selectedTag) => {
        // Update active state
        buttons.forEach(btn => {
          const btnTag = btn.getAttribute('data-tag');
          if (btnTag === selectedTag) {
            btn.classList.add('btn-primary', 'active');
            btn.classList.remove('btn-outline', 'btn-ghost');
          } else {
            btn.classList.remove('btn-primary', 'active');
            btn.classList.add('btn-outline', 'btn-ghost');
          }
        });

        // Filter items
        items.forEach(item => {
          const itemTags = item.getAttribute('data-filter-tags').split(',').map(t => t.trim().toLowerCase());
          
          if (selectedTag === 'all' || itemTags.includes(selectedTag)) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
      };

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          filterByTag(button.getAttribute('data-tag'));
        });
      });

      // Handle deep linking from URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      const urlTag = urlParams.get('tag')?.toLowerCase();
      if (urlTag) {
        // Check if the tag exists in our filter
        const targetBtn = Array.from(buttons).find(btn => btn.getAttribute('data-tag') === urlTag);
        if (targetBtn) {
          filterByTag(urlTag);
        }
      }
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFilter);
  } else {
    initFilter();
  }
</script>

<style>
  .filter-btn.active {
    pointer-events: none;
  }
</style>
