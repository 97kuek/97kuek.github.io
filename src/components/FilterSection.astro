---
import { useTranslations, type Lang } from "../i18n/ui";

interface Props {
  tags: string[];
  containerId: string;
  tagCounts?: Record<string, number>;
  totalCount?: number;
  /** How many tags to show before collapsing the rest behind "show all". */
  initialVisible?: number;
}

const { tags, containerId, tagCounts, totalCount, initialVisible = 10 } = Astro.props;
const isEn = (Astro.currentLocale ?? "ja") === "en";
const t = useTranslations((Astro.currentLocale ?? "ja") as Lang);

const noResultsMsg = t("filter.noResults");
const resetLabel = t("filter.reset");
const itemsSuffix = t("filter.items");

const extraCount = Math.max(0, tags.length - initialVisible);
const moreLabel = isEn ? `Show all tags (+${extraCount})` : `すべてのタグ (+${extraCount})`;
const lessLabel = isEn ? "Show less" : "閉じる";
---

<div class="mb-8" id={`filter-section-${containerId}`}>
  <button
    id={`filter-toggle-${containerId}`}
    class="flex items-center justify-between w-full mb-4 px-2 py-1 group hover:bg-base-200/50 rounded-lg transition-colors duration-200"
    aria-expanded="true"
    aria-controls={`filter-content-${containerId}`}
  >
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
      </svg>
      <span class="font-bold text-sm tracking-wide uppercase">Tags</span>
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="chevron transition-transform duration-300"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div id={`filter-content-${containerId}`} class="transition-all duration-300 ease-in-out overflow-hidden">
    <div class="flex flex-wrap gap-2 mb-4" id={`filter-${containerId}`}>
      <button
        class="btn btn-sm btn-primary filter-btn active"
        data-tag="all"
      >
        All {totalCount !== undefined && <span class="opacity-70">({totalCount})</span>}
      </button>
      {
        tags.map((tag, i) => (
          <button
            class:list={[
              "btn btn-sm btn-outline btn-ghost filter-btn",
              i >= initialVisible && "filter-tag-extra hidden",
            ]}
            data-tag={tag.toLowerCase()}
          >
            {tag} {tagCounts?.[tag] !== undefined && <span class="opacity-70">({tagCounts[tag]})</span>}
          </button>
        ))
      }
      {
        extraCount > 0 && (
          <button
            type="button"
            class="btn btn-sm btn-ghost text-base-content/60 toggle-more-tags"
            data-more-label={moreLabel}
            data-less-label={lessLabel}
          >
            {moreLabel}
          </button>
        )
      }
    </div>
  </div>

  <div class="flex items-center justify-between px-2 text-sm text-base-content/60">
    <div id={`results-count-${containerId}`}>
      {totalCount !== undefined ? `${totalCount}${itemsSuffix}` : ''}
    </div>
  </div>

  <div
    id={`no-results-${containerId}`}
    class="hidden text-center py-20 border-2 border-dashed border-base-300 rounded-xl mt-4"
  >
    <p class="text-xl text-base-content/50">{noResultsMsg}</p>
    <button class="btn btn-ghost btn-sm mt-4 reset-filters">
      {resetLabel}
    </button>
  </div>
</div>

<script define:vars={{ containerId, itemsSuffix }}>
  let cleanupFilter;

  const initFilter = () => {
    cleanupFilter?.();
    cleanupFilter = undefined;

    const filterRoot = document.getElementById(`filter-section-${containerId}`);
    const filterSection = document.getElementById(`filter-${containerId}`);
    const container = document.getElementById(containerId);
    const countDisplay = document.getElementById(`results-count-${containerId}`);
    const noResults = document.getElementById(`no-results-${containerId}`);

    if (filterSection && container && countDisplay && noResults) {
      const cleanups = [];
      const toggle = document.getElementById(`filter-toggle-${containerId}`);
      const content = document.getElementById(`filter-content-${containerId}`);
      const chevron = toggle?.querySelector('.chevron');

      const buttons = filterSection.querySelectorAll('.filter-btn');
      const prefersCollapsed = window.matchMedia('(max-width: 767px)');

      const setExpanded = (expanded, focusFirst = false) => {
        if (!toggle || !content || !chevron) return;
        toggle.setAttribute('aria-expanded', expanded.toString());
        content.toggleAttribute('inert', !expanded);

        if (expanded) {
          content.hidden = false;
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          chevron.classList.remove('-rotate-90');
          if (focusFirst) {
            setTimeout(() => {
              const firstBtn = content.querySelector('.filter-btn');
              if (firstBtn) firstBtn.focus();
            }, 200);
          }
        } else {
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
          chevron.classList.add('-rotate-90');
          setTimeout(() => {
            if (toggle.getAttribute('aria-expanded') !== 'true') {
              content.hidden = true;
            }
          }, 300);
        }
      };

      if (toggle && content && chevron) {
        setExpanded(!prefersCollapsed.matches);

        const onToggleClick = () => {
          const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
          setExpanded(!isExpanded, !isExpanded);
        };
        toggle.addEventListener('click', onToggleClick);
        cleanups.push(() => toggle.removeEventListener('click', onToggleClick));

        const onMediaChange = (event) => {
          setExpanded(!event.matches);
        };
        prefersCollapsed.addEventListener('change', onMediaChange);
        cleanups.push(() => prefersCollapsed.removeEventListener('change', onMediaChange));
      }

      // "Show all tags" toggle — reveals the overflow tags and re-measures the
      // collapsible panel height so the open animation stays correct.
      const moreBtn = filterRoot.querySelector('.toggle-more-tags');
      if (moreBtn) {
        const onMoreClick = () => {
          const extras = filterSection.querySelectorAll('.filter-tag-extra');
          const willShow = extras.length > 0 && extras[0].classList.contains('hidden');
          extras.forEach((el) => el.classList.toggle('hidden', !willShow));
          moreBtn.textContent = willShow
            ? moreBtn.getAttribute('data-less-label')
            : moreBtn.getAttribute('data-more-label');
          if (content && toggle?.getAttribute('aria-expanded') === 'true') {
            content.style.maxHeight = content.scrollHeight + 'px';
          }
        };
        moreBtn.addEventListener('click', onMoreClick);
        cleanups.push(() => moreBtn.removeEventListener('click', onMoreClick));
      }

      const resetBtn = filterRoot.querySelector('.reset-filters');
      const items = container.querySelectorAll('[data-filter-tags]');
      let activeTags = new Set();

      const updateUI = (updateUrl = true) => {
        let visibleCount = 0;

        buttons.forEach(btn => {
          const btnTag = btn.getAttribute('data-tag');
          if (btnTag === 'all') {
            if (activeTags.size === 0) {
              btn.classList.add('btn-primary', 'active');
              btn.classList.remove('btn-outline', 'btn-ghost');
            } else {
              btn.classList.remove('btn-primary', 'active');
              btn.classList.add('btn-outline', 'btn-ghost');
            }
          } else {
            // Selected content tags use the teal secondary; coral stays for "All".
            if (activeTags.has(btnTag)) {
              btn.classList.add('btn-secondary', 'active');
              btn.classList.remove('btn-outline', 'btn-ghost');
            } else {
              btn.classList.remove('btn-secondary', 'active');
              btn.classList.add('btn-outline', 'btn-ghost');
            }
          }
        });

        if (content && toggle?.getAttribute('aria-expanded') === 'true') {
          content.style.maxHeight = content.scrollHeight + 'px';
        }

        items.forEach(item => {
          const itemTags = item.getAttribute('data-filter-tags').split(',').map(t => t.trim().toLowerCase());
          const isVisible = activeTags.size === 0 || Array.from(activeTags).every(tag => itemTags.includes(tag));

          if (isVisible) {
            item.style.display = '';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        countDisplay.textContent = `${visibleCount}${itemsSuffix}`;
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          container.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          container.classList.remove('hidden');
        }

        if (updateUrl) {
          const url = new URL(window.location.href);
          url.searchParams.delete('tag');
          activeTags.forEach(tag => url.searchParams.append('tag', tag));
          if (url.toString() !== window.location.href) {
            window.history.pushState({ tags: Array.from(activeTags) }, '', url);
          }
        }
      };

      const toggleTag = (tag) => {
        if (tag === 'all') {
          activeTags.clear();
        } else {
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
          } else {
            activeTags.add(tag);
          }
        }
        updateUI();
      };

      buttons.forEach(button => {
        const onButtonClick = () => {
          toggleTag(button.getAttribute('data-tag'));
        };
        button.addEventListener('click', onButtonClick);
        cleanups.push(() => button.removeEventListener('click', onButtonClick));
      });

      if (resetBtn) {
        const onResetClick = () => {
          activeTags.clear();
          updateUI();
        };
        resetBtn.addEventListener('click', onResetClick);
        cleanups.push(() => resetBtn.removeEventListener('click', onResetClick));
      }

      const syncFromUrl = () => {
        const urlParams = new URLSearchParams(window.location.search);
        const urlTags = urlParams.getAll('tag');
        activeTags.clear();
        urlTags.forEach(tag => {
          const lowerTag = tag.toLowerCase();
          const targetBtn = Array.from(buttons).find(btn => btn.getAttribute('data-tag') === lowerTag);
          if (targetBtn) {
            activeTags.add(lowerTag);
          }
        });
        // If a deep-linked tag lives in the collapsed overflow, reveal it.
        const anyHiddenActive = Array.from(activeTags).some((tag) => {
          const btn = Array.from(buttons).find((b) => b.getAttribute('data-tag') === tag);
          return btn && btn.classList.contains('filter-tag-extra');
        });
        if (anyHiddenActive && moreBtn) {
          filterSection.querySelectorAll('.filter-tag-extra').forEach((el) => el.classList.remove('hidden'));
          moreBtn.textContent = moreBtn.getAttribute('data-less-label');
        }
        updateUI(false);
      };

      const onPopState = () => {
        syncFromUrl();
      };
      window.addEventListener('popstate', onPopState);
      cleanups.push(() => window.removeEventListener('popstate', onPopState));

      syncFromUrl();
      cleanupFilter = () => {
        cleanups.forEach((cleanup) => cleanup());
      };
    }
  };

  document.addEventListener('astro:page-load', initFilter);
  document.addEventListener('astro:before-swap', () => cleanupFilter?.());
</script>

<style>
  .filter-btn.active[data-tag="all"] {
    pointer-events: none;
  }
</style>
