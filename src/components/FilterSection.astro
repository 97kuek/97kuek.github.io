---
interface Props {
  tags: string[];
  containerId: string;
  tagCounts?: Record<string, number>;
  totalCount?: number;
}

const { tags, containerId, tagCounts, totalCount } = Astro.props;
---

<div class="mb-8" id={`filter-section-${containerId}`}>
  <button 
    id={`filter-toggle-${containerId}`}
    class="flex items-center justify-between w-full mb-4 px-2 py-1 group hover:bg-base-200/50 rounded-lg transition-colors duration-200"
    aria-expanded="false"
    aria-controls={`filter-content-${containerId}`}
  >
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
      </svg>
      <span class="font-bold text-sm tracking-wide uppercase">Tags</span>
    </div>
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      width="18" 
      height="18" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round" 
      class="chevron transition-transform duration-300 -rotate-90"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div id={`filter-content-${containerId}`} class="transition-all duration-300 ease-in-out overflow-hidden opacity-0 max-h-0">
    <div class="flex flex-wrap gap-2 mb-4" id={`filter-${containerId}`}>
      <button
        class="btn btn-sm btn-primary filter-btn active"
        data-tag="all"
      >
        All {totalCount !== undefined && <span class="opacity-70">({totalCount})</span>}
      </button>
      {
        tags.map((tag) => (
          <button
            class="btn btn-sm btn-outline btn-ghost filter-btn"
            data-tag={tag.toLowerCase()}
          >
            {tag} {tagCounts?.[tag] !== undefined && <span class="opacity-70">({tagCounts[tag]})</span>}
          </button>
        ))
      }
    </div>
  </div>

  <div class="flex items-center justify-between px-2 text-sm text-base-content/60">
    <div id={`results-count-${containerId}`}>
      {totalCount !== undefined ? `${totalCount} item${totalCount !== 1 ? 's' : ''} found` : ''}
    </div>
  </div>

  <div 
    id={`no-results-${containerId}`} 
    class="hidden text-center py-20 border-2 border-dashed border-base-300 rounded-xl mt-4"
  >
    <p class="text-xl text-base-content/50">No items match the selected filters.</p>
    <button class="btn btn-ghost btn-sm mt-4 reset-filters">
      Clear all filters
    </button>
  </div>
</div>

<script define:vars={{ containerId }}>
  const initFilter = () => {
    const filterRoot = document.getElementById(`filter-section-${containerId}`);
    const filterSection = document.getElementById(`filter-${containerId}`);
    const container = document.getElementById(containerId);
    const countDisplay = document.getElementById(`results-count-${containerId}`);
    const noResults = document.getElementById(`no-results-${containerId}`);
    
    if (filterSection && container && countDisplay && noResults) {
      const toggle = document.getElementById(`filter-toggle-${containerId}`);
      const content = document.getElementById(`filter-content-${containerId}`);
      const chevron = toggle?.querySelector('.chevron');
      
      const buttons = filterSection.querySelectorAll('.filter-btn');

      if (toggle && content && chevron) {
        toggle.addEventListener('click', () => {
          const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', (!isExpanded).toString());
          
          if (isExpanded) {
            content.style.maxHeight = '0px';
            content.style.opacity = '0';
            chevron.classList.add('-rotate-90');
          } else {
            content.style.maxHeight = content.scrollHeight + 'px';
            content.style.opacity = '1';
            chevron.classList.remove('-rotate-90');
          }
        });
      }

      const resetBtn = filterRoot.querySelector('.reset-filters');
      const items = container.querySelectorAll('[data-filter-tags]');
      let activeTags = new Set();

      const updateUI = (updateUrl = true) => {
        let visibleCount = 0;

        // Update button states
        buttons.forEach(btn => {
          const btnTag = btn.getAttribute('data-tag');
          if (btnTag === 'all') {
            if (activeTags.size === 0) {
              btn.classList.add('btn-primary', 'active');
              btn.classList.remove('btn-outline', 'btn-ghost');
            } else {
              btn.classList.remove('btn-primary', 'active');
              btn.classList.add('btn-outline', 'btn-ghost');
            }
          } else {
            if (activeTags.has(btnTag)) {
              btn.classList.add('btn-primary', 'active');
              btn.classList.remove('btn-outline', 'btn-ghost');
            } else {
              btn.classList.remove('btn-primary', 'active');
              btn.classList.add('btn-outline', 'btn-ghost');
            }
          }
        });

        // Filter items with AND logic
        items.forEach(item => {
          const itemTags = item.getAttribute('data-filter-tags').split(',').map(t => t.trim().toLowerCase());
          const isVisible = activeTags.size === 0 || Array.from(activeTags).every(tag => itemTags.includes(tag));
          
          if (isVisible) {
            item.style.display = '';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        // Update count and no-results message
        countDisplay.textContent = `${visibleCount} item${visibleCount !== 1 ? 's' : ''} found`;
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          container.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          container.classList.remove('hidden');
        }

        // Synchronize with URL
        if (updateUrl) {
          const url = new URL(window.location.href);
          url.searchParams.delete('tag');
          activeTags.forEach(tag => url.searchParams.append('tag', tag));
          
          // Only push state if the URL actually changed to avoid history bloating
          if (url.toString() !== window.location.href) {
            window.history.pushState({ tags: Array.from(activeTags) }, '', url);
          }
        }
      };

      const toggleTag = (tag) => {
        if (tag === 'all') {
          activeTags.clear();
        } else {
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
          } else {
            activeTags.add(tag);
          }
        }
        updateUI();
      };

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          toggleTag(button.getAttribute('data-tag'));
        });
      });

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          activeTags.clear();
          updateUI();
        });
      }

      // Handle deep linking from URL parameters
      const syncFromUrl = () => {
        const urlParams = new URLSearchParams(window.location.search);
        const urlTags = urlParams.getAll('tag');
        activeTags.clear();
        urlTags.forEach(tag => {
          const lowerTag = tag.toLowerCase();
          const targetBtn = Array.from(buttons).find(btn => btn.getAttribute('data-tag') === lowerTag);
          if (targetBtn) {
            activeTags.add(lowerTag);
          }
        });
        updateUI(false); // Don't push state again
      };

      // Handle browser back/forward
      window.addEventListener('popstate', (event) => {
        syncFromUrl();
      });

      // Initial sync
      syncFromUrl();
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFilter);
  } else {
    initFilter();
  }
</script>

<style>
  .filter-btn.active[data-tag="all"] {
    pointer-events: none;
  }
</style>
