---
const { cols = 3, caption } = Astro.props;
---

<figure class="not-prose my-8 max-w-3xl mx-auto">
  <div style={`columns: ${cols}; column-gap: 0.5rem;`}>
    <slot />
  </div>
  {caption && (
    <figcaption class="text-center text-sm text-base-content/55 mt-2">
      {caption}
    </figcaption>
  )}
</figure>
