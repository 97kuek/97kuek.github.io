---
interface Props {
  id: string;
  title: string;
  tags?: string[];
  label?: string;
  showText?: boolean;
}

const { id, title, tags = [], label, showText = true } = Astro.props;

const gradId = `og-grad-${id.replace(/[^a-zA-Z0-9]/g, "-")}`;

// Word-wrap: target ~22 chars per line at font-size 36
const words = title.split(/\s+/);
const lines: string[] = [];
let cur = "";
for (const word of words) {
  const next = cur ? `${cur} ${word}` : word;
  if (next.length > 22 && cur.length > 0) {
    lines.push(cur);
    cur = word;
  } else {
    cur = next;
  }
}
if (cur) lines.push(cur);

const maxLines = 4;
const capped = lines.slice(0, maxLines);
if (lines.length > maxLines) capped[maxLines - 1] += "…";

const lineHeight = 50;
const totalH = capped.length * lineHeight;
const startY = 210 - totalH / 2 + lineHeight * 0.8;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 800 450"
  style="display:block;width:100%;height:100%;"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#4f46e5" />
      <stop offset="100%" stop-color="#7c3aed" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill={`url(#${gradId})`} />

  <!-- Decorative circles -->
  <circle cx="720" cy="-20" r="200" fill="rgba(255,255,255,0.07)" />
  <circle cx="80" cy="470" r="180" fill="rgba(255,255,255,0.07)" />
  <circle cx="400" cy="225" r="280" fill="rgba(255,255,255,0.025)" />

  {showText && (
    <Fragment>
      <!-- Bottom tint bar -->
      <rect y="390" width="800" height="60" fill="rgba(0,0,0,0.3)" />

      <!-- Label (category) -->
      {label && (
        <text
          x="52"
          y="68"
          fill="rgba(255,255,255,0.55)"
          font-size="14"
          font-family="system-ui,-apple-system,sans-serif"
          font-weight="600"
          letter-spacing="2.5"
        >
          {label.toUpperCase()}
        </text>
      )}

      <!-- Accent line -->
      <rect
        x="48"
        y={label ? 80 : 30}
        width="44"
        height="3"
        rx="1.5"
        fill="rgba(255,255,255,0.45)"
      />

      <!-- Title lines -->
      {capped.map((line, i) => (
        <text
          x="52"
          y={startY + i * lineHeight}
          fill="white"
          font-size="36"
          font-weight="700"
          font-family="system-ui,-apple-system,sans-serif"
        >
          {line}
        </text>
      ))}

      <!-- Tag pills -->
      {tags.slice(0, 4).map((tag, i) => {
        const x = 52 + i * 150;
        const displayTag = tag.length > 14 ? tag.slice(0, 13) + "…" : tag;
        return (
          <g>
            <rect
              x={x}
              y="403"
              width="138"
              height="28"
              rx="14"
              fill="rgba(255,255,255,0.2)"
            />
            <text
              x={x + 69}
              y="422"
              text-anchor="middle"
              fill="rgba(255,255,255,0.9)"
              font-size="13"
              font-family="system-ui,-apple-system,sans-serif"
            >
              {displayTag}
            </text>
          </g>
        );
      })}
    </Fragment>
  )}
</svg>
