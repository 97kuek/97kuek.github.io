---
import { OG_COLORS, wrapTitle } from "../utils/ogImage";

interface Props {
  id: string;
  title: string;
  tags?: string[];
  label?: string;
  showText?: boolean;
  minimal?: boolean;
}

const { id, title, tags = [], label, showText = true, minimal = false } = Astro.props;

const lines = wrapTitle(title);

const maxLines = 3;
const capped = lines.slice(0, maxLines);
if (lines.length > maxLines) capped[maxLines - 1] += "...";

const lineHeight = 46;
const totalH = capped.length * lineHeight;
const startY = 210 - totalH / 2 + lineHeight * 0.8;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 800 450"
  style="display:block;width:100%;height:100%;"
  aria-hidden="true"
>
  <!-- Background (warm cream to match the site canvas) -->
  <rect width="800" height="450" fill={minimal ? OG_COLORS.surface : OG_COLORS.canvas} />

  <!-- Subtle border -->
  <rect width="800" height="450" fill="none" stroke={minimal ? OG_COLORS.divider : OG_COLORS.border} stroke-width="2" />

  {minimal && label && (
    <Fragment>
      <text
        x="400"
        y="225"
        text-anchor="middle"
        dominant-baseline="middle"
        fill={OG_COLORS.muted}
        font-size="44"
        font-family="system-ui,-apple-system,sans-serif"
        font-weight="700"
        letter-spacing="8"
      >
        {label.toUpperCase()}
      </text>
    </Fragment>
  )}

  {!minimal && showText && (
    <Fragment>
      <!-- Left accent bar (coral brand touch) -->
      <rect x="52" y="60" width="4" height="36" rx="2" fill={OG_COLORS.label} />

      <!-- Label -->
      {label && (
        <text
          x="66"
          y="84"
          fill={OG_COLORS.muted}
          font-size="13"
          font-family="system-ui,-apple-system,sans-serif"
          font-weight="700"
          letter-spacing="2"
        >
          {label.toUpperCase()}
        </text>
      )}

      <!-- Title lines -->
      {capped.map((line, i) => (
        <text
          x="52"
          y={startY + i * lineHeight}
          fill={OG_COLORS.title}
          font-size="34"
          font-weight="700"
          font-family="system-ui,-apple-system,sans-serif"
        >
          {line}
        </text>
      ))}

      <!-- Tag badges -->
      {tags.slice(0, 5).map((tag, i) => {
        const x = 52 + i * 148;
        const displayTag = tag.length > 14 ? tag.slice(0, 13) + "..." : tag;
        return (
          <g>
            <rect
              x={x}
              y="390"
              width="136"
              height="26"
              rx="13"
              fill={OG_COLORS.tag}
            />
            <text
              x={x + 68}
              y="407"
              text-anchor="middle"
              fill={OG_COLORS.tagText}
              font-size="12"
              font-family="system-ui,-apple-system,sans-serif"
            >
              {displayTag}
            </text>
          </g>
        );
      })}
    </Fragment>
  )}
</svg>
