---
interface Props {
  id: string;
  title: string;
  tags?: string[];
  label?: string;
  showText?: boolean;
  minimal?: boolean;
}

const { id, title, tags = [], label, showText = true, minimal = false } = Astro.props;

function wrapTitle(text: string, maxWidth = 16): string[] {
  const isCJK = (ch: string) =>
    /[⺀-鿿豈-﫿︰-﹏！-｠￠-￦]/.test(ch);
  const lines: string[] = [];
  let cur = "";
  let curW = 0;
  for (const ch of text) {
    const w = isCJK(ch) ? 1 : 0.55;
    if (curW + w > maxWidth && cur.length > 0) {
      lines.push(cur);
      cur = ch;
      curW = w;
    } else {
      cur += ch;
      curW += w;
    }
  }
  if (cur) lines.push(cur);
  return lines;
}

const lines = wrapTitle(title);

const maxLines = 3;
const capped = lines.slice(0, maxLines);
if (lines.length > maxLines) capped[maxLines - 1] += "…";

const lineHeight = 46;
const totalH = capped.length * lineHeight;
const startY = 210 - totalH / 2 + lineHeight * 0.8;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 800 450"
  style="display:block;width:100%;height:100%;"
  aria-hidden="true"
>
  <!-- Background -->
  <rect width="800" height="450" fill={minimal ? "#edf1f7" : "#f8fafc"} />

  <!-- Subtle border -->
  <rect width="800" height="450" fill="none" stroke={minimal ? "#cfd7e6" : "#e2e8f0"} stroke-width="2" />

  {minimal && label && (
    <Fragment>
      <text
        x="400"
        y="225"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#4a5568"
        font-size="44"
        font-family="system-ui,-apple-system,sans-serif"
        font-weight="700"
        letter-spacing="8"
      >
        {label.toUpperCase()}
      </text>
    </Fragment>
  )}

  {!minimal && showText && (
    <Fragment>
      <!-- Left accent bar -->
      <rect x="52" y="60" width="4" height="36" rx="2" fill="#4a5568" />

      <!-- Label -->
      {label && (
        <text
          x="66"
          y="84"
          fill="#4a5568"
          font-size="13"
          font-family="system-ui,-apple-system,sans-serif"
          font-weight="700"
          letter-spacing="2"
        >
          {label.toUpperCase()}
        </text>
      )}

      <!-- Title lines -->
      {capped.map((line, i) => (
        <text
          x="52"
          y={startY + i * lineHeight}
          fill="#1e293b"
          font-size="34"
          font-weight="700"
          font-family="system-ui,-apple-system,sans-serif"
        >
          {line}
        </text>
      ))}

      <!-- Tag badges -->
      {tags.slice(0, 5).map((tag, i) => {
        const x = 52 + i * 148;
        const displayTag = tag.length > 14 ? tag.slice(0, 13) + "…" : tag;
        return (
          <g>
            <rect
              x={x}
              y="390"
              width="136"
              height="26"
              rx="13"
              fill="#e2e8f0"
            />
            <text
              x={x + 68}
              y="407"
              text-anchor="middle"
              fill="#475569"
              font-size="12"
              font-family="system-ui,-apple-system,sans-serif"
            >
              {displayTag}
            </text>
          </g>
        );
      })}
    </Fragment>
  )}
</svg>
